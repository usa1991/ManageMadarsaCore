@{
    ViewData["Title"] = "About Us";
}

<!-- Hero Banner -->
    <header class="section-cream" style="padding: 160px 0 80px;">
        <div class="container" style="text-align: center;">
            <div class="badge">ABOUT US</div>
            <h1 style="font-size: 3.2rem; margin-bottom: 24px;">Empowering Madarsas globally.</h1>
            <p style="font-size: 1.1rem; color: var(--text-muted); max-width: 600px; margin: 0 auto;">Learn about our history, our values, and why thousands of parents and teachers trust Deeniyat.</p>
        </div>
    </header>

    <!-- History -->
    <section class="section-white">
        <div class="container hero-grid">
            <div class="hero-image">
                <img src="../images/history.jpg" onerror="this.src='https://images.unsplash.com/photo-1461360370896-922624d12aa1?auto=format&fit=crop&q=80&w=800';" alt="History of Deeniyat">
            </div>
            <div>
                <h2 style="font-size: 2.25rem; margin-bottom: 20px;">History of Deeniyat</h2>
                <p style="color: var(--text-muted); margin-bottom: 16px;">Deeniyat Educational & Charitable Trust started doing work from mosques a few years ago. We created an excellent system of religious education through organized maktabs, and at the same time started management of formal schools established in the vicinity of mosques.</p>
                <p style="color: var(--text-muted);">Over the years, we have expanded our mission to spread education, social justice, and humanity across the entire world, leveraging modern technology to make administration seamless.</p>
            </div>
        </div>
    </section>

    <!-- Mission & Vision -->
    <section class="section-cream">
        <div class="container">
            <div class="feature-grid" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));">
                <div class="feature-card">
                    <div style="color: var(--primary); font-size: 2.5rem; margin-bottom: 16px;"><i class="ph-fill ph-target"></i></div>
                    <h3>Our Mission</h3>
                    <p>To pass on the experience gained over the years to others quickly and easily through our Apps and Website so everyone can understand the work of education and social service and execute it efficiently from their mosque or any other place.</p>
                </div>
                <div class="feature-card">
                    <div style="color: var(--primary); font-size: 2.5rem; margin-bottom: 16px;"><i class="ph-fill ph-eye"></i></div>
                    <h3>Our Vision</h3>
                    <p>That the life and wealth of persons involved in this work can be utilized in the best possible manner, and that education, social justice, and humanity can be spread in the entire world. <br><br><a href="vision.html" style="color: var(--primary); font-weight: 600;">Read our full vision &rarr;</a></p>
                </div>
            </div>
        </div>
    </section>

    <!-- Core Values -->
    <section class="section-white">
        <div class="container">
            <div class="section-header">
                <h2>Core Values</h2>
                <p>The principles that guide everything we do.</p>
            </div>
            <div class="feature-grid">
                <div class="feature-card" style="text-align: center;">
                    <i class="ph-fill ph-heart" style="font-size: 2.5rem; color: var(--primary); margin-bottom: 16px; display: inline-block;"></i>
                    <h3>Integrity</h3>
                    <p>We uphold the highest moral standards in our operations and teachings.</p>
                </div>
                <div class="feature-card" style="text-align: center;">
                    <i class="ph-fill ph-users-three" style="font-size: 2.5rem; color: var(--primary); margin-bottom: 16px; display: inline-block;"></i>
                    <h3>Community</h3>
                    <p>Building strong, supportive networks around every mosque and maktab.</p>
                </div>
                <div class="feature-card" style="text-align: center;">
                    <i class="ph-fill ph-lightbulb" style="font-size: 2.5rem; color: var(--primary); margin-bottom: 16px; display: inline-block;"></i>
                    <h3>Excellence</h3>
                    <p>Providing the best digital tools for religious and modern education.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Principal's Message -->
    <section class="section-cream">
        <div class="container" style="max-width: 800px; text-align: center;">
            <div style="margin-bottom: 24px;">
                <img src="../images/principal.jpg" onerror="this.src='https://ui-avatars.com/api/?name=principal&background=a2ae40&color=fff&size=400';" alt="Principal" style="width: 120px; height: 120px; border-radius: 50%; border: 4px solid white; box-shadow: 0 10px 20px rgba(0,0,0,0.1);">
            </div>
            <h2 style="font-size: 2rem; margin-bottom: 16px;">Principal's Message</h2>
            <p style="font-size: 1.15rem; color: var(--text-muted); font-style: italic; line-height: 1.8; margin-bottom: 24px;">"Our goal is not just to impart knowledge, but to nurture character. With Deeniyat, we are bridging the gap between traditional values and modern convenience, ensuring our students are prepared for both this world and the hereafter."</p>
            <h4 style="color: var(--text-main); font-size: 1.1rem; margin-bottom: 4px;">Maulana Ahmed</h4>
            <span style="color: var(--primary); font-size: 0.9rem; font-weight: 600;">Principal, Deeniyat Trust</span>
        </div>
    </section>

    <!-- Timeline -->
    <section class="section-white">
        <div class="container">
            <div class="section-header">
                <h2>Our Journey</h2>
                <p>The milestones that defined our growth.</p>
            </div>
            <div class="timeline">
                <div class="timeline-item">
                    <div class="timeline-year">2015</div>
                    <div class="timeline-content">
                        <h3>Founded</h3>
<!-- made by "He is The Usman (≖⩊≖)" -->
                        <p>Deeniyat Educational & Charitable Trust was established to organize maktab education.</p>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-year">2018</div>
                    <div class="timeline-content">
                        <h3>Expansion</h3>
                        <p>Began managing formal schools in the vicinity of mosques.</p>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-year">2021</div>
                    <div class="timeline-content">
                        <h3>Digital Learning</h3>
                        <p>Launched Apps and Website to pass on our experience quickly and easily.</p>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-year">2024</div>
                    <div class="timeline-content">
                        <h3>500+ Students</h3>
                        <p>Reached a milestone of empowering over 500 institutions and students globally.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Our Teaching Philosophy -->
    <section class="section-cream">
        <div class="container" style="text-align: center; max-width: 800px;">
            <h2 style="font-size: 2.25rem; margin-bottom: 24px;">Our Teaching Philosophy</h2>
            <p style="color: var(--text-muted); font-size: 1.1rem; line-height: 1.8;">We believe in a holistic approach to education. By working from mosques, it becomes easier to get more volunteers and gives people easy access to take advantage of our structured curriculum. We focus on Education, Worship, Social Service, and Invitation towards Deen.</p>
        </div>
    </section>

    <!-- Why Parents Trust Us -->
    <section class="section-white">
        <div class="container">
            <div class="section-header">
                <h2>Why Parents Trust Us</h2>
            </div>
            <div class="feature-grid">
                <div class="feature-card">
                    <i class="ph-fill ph-shield-check" style="font-size: 2.5rem; color: var(--primary); margin-bottom: 16px; display: inline-block;"></i>
                    <h3>Safe Environment</h3>
                    <p>We ensure a nurturing and secure environment for all students.</p>
                </div>
                <div class="feature-card">
                    <i class="ph-fill ph-chart-line-up" style="font-size: 2.5rem; color: var(--primary); margin-bottom: 16px; display: inline-block;"></i>
                    <h3>Transparent Progress</h3>
                    <p>Parents can easily track their child's daily progress and exam reports through our app.</p>
                </div>
                <div class="feature-card">
                    <i class="ph-fill ph-book-open" style="font-size: 2.5rem; color: var(--primary); margin-bottom: 16px; display: inline-block;"></i>
                    <h3>Balanced Education</h3>
                    <p>Seamless integration of religious and contemporary studies.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Call To Action -->
    <section class="section-cream">
        <div class="container" style="text-align: center; padding: 40px 0;">
            <h2 style="font-size: 2.5rem; margin-bottom: 20px;">Join Our Family</h2>
            <p style="color: var(--text-muted); font-size: 1.1rem; margin-bottom: 30px; max-width: 600px; margin-left: auto; margin-right: auto;">Be a part of a growing community dedicated to excellent religious and modern education.</p>
            <a href="#" class="btn-primary" style="font-size: 1.1rem; padding: 14px 32px;">Get Started Today</a>
        </div>
    </section>

    <!-- Footer -->
