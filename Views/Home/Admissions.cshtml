@{
    ViewData["Title"] = "Admissions";
}

<header class="hero section-cream">
        <div class="container hero-grid" style="text-align: center; display: block;">
            <div class="badge fade-up">JOIN OUR FAMILY</div>
            <h1 class="fade-up">Admissions</h1>
            <p class="fade-up" style="max-width: 600px; margin: 0 auto 30px;">Begin your child's journey of Islamic and modern education. Our transparent admission process ensures a smooth onboarding experience for both students and parents.</p>
        </div>
    </header>

    <section class="section-white">
        <div class="container">
            <div class="section-header text-center fade-up">
                <h2>Admission Process</h2>
                <p>Three simple steps to join Deeniyat</p>
            </div>
            
            <div class="steps-container fade-up">
                <div class="step-card">
                    <div class="step-number">1</div>
                    <i class="ph-fill ph-file-text" style="font-size: 2.5rem; color: var(--primary); margin-bottom: 15px;"></i>
                    <h3>Fill Form</h3>
                    <p>Complete the online application form with accurate student and parent details.</p>
                </div>
                <div class="step-card">
                    <div class="step-number">2</div>
                    <i class="ph-fill ph-users-three" style="font-size: 2.5rem; color: var(--primary); margin-bottom: 15px;"></i>
                    <h3>Interview</h3>
                    <p>Attend a brief interactive session with our academic panel to assess the student's level.</p>
                </div>
                <div class="step-card">
                    <div class="step-number">3</div>
                    <i class="ph-fill ph-check-circle" style="font-size: 2.5rem; color: var(--primary); margin-bottom: 15px;"></i>
                    <h3>Confirmation</h3>
                    <p>Submit required documents, pay the admission fee, and receive the confirmation letter.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="section-cream">
        <div class="container">
            <div class="section-header text-center fade-up">
                <h2>Online Admission Form</h2>
                <p>Fill out the application below to register your interest.</p>
            </div>
            
            <div class="admission-form-wrapper fade-up">
                <form action="#" method="POST" onsubmit="event.preventDefault(); alert('Form submitted successfully!');">
                    
                    <div class="form-section">
                        <h3><i class="ph-fill ph-student"></i> Student Details</h3>
                        <div class="form-row">
                            <div class="form-group">
                                <label for="firstName">First Name</label>
                                <input type="text" id="firstName" class="form-control" required placeholder="Enter student's first name">
                            </div>
                            <div class="form-group">
                                <label for="lastName">Last Name</label>
                                <input type="text" id="lastName" class="form-control" required placeholder="Enter student's last name">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label for="dob">Date of Birth</label>
                                <input type="date" id="dob" class="form-control" required>
                            </div>
                            <div class="form-group">
                                <label for="gender">Gender</label>
                                <select id="gender" class="form-control" required>
                                    <option value="">Select Gender</option>
                                    <option value="male">Male</option>
                                    <option value="female">Female</option>
                                </select>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label for="course">Course Applying For</label>
                                <select id="course" class="form-control" required>
                                    <option value="">Select Course</option>
                                    <option value="hifz">Hifz</option>
                                    <option value="qaida">Qaida</option>
                                    <option value="nazira">Quran Reading (Nazira)</option>
                                    <option value="alim">Alim Course</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    
                    <div class="form-section">
                        <h3><i class="ph-fill ph-users"></i> Parent/Guardian Details</h3>
                        <div class="form-row">
                            <div class="form-group">
                                <label for="parentName">Father/Guardian Name</label>
                                <input type="text" id="parentName" class="form-control" required placeholder="Enter full name">
                            </div>
                            <div class="form-group">
                                <label for="phone">Phone Number</label>
                                <input type="tel" id="phone" class="form-control" required placeholder="+1 (234) 567-8900">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label for="email">Email Address</label>
                                <input type="email" id="email" class="form-control" required placeholder="your@email.com">
                            </div>
                            <div class="form-group">
                                <label for="address">Home Address</label>
                                <input type="text" id="address" class="form-control" required placeholder="Enter complete address">
                            </div>
                        </div>
                    </div>
                    
                    <div class="form-section">
                        <h3><i class="ph-fill ph-upload-simple"></i> Documents Upload</h3>
                        <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 15px;">Please upload scanned copies (PDF or JPG). Max size 5MB each.</p>
                        
                        <div class="form-row">
                            <div class="form-group">
                                <label>Birth Certificate</label>
                                <div class="file-upload">
                                    <i class="ph-bold ph-upload-simple" style="font-size: 1.5rem; color: var(--text-muted);"></i>
                                    <p style="margin-top: 5px; font-size: 0.9rem; color: var(--text-muted);">Click to browse or drag file here</p>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Previous Madarsa Record (If any)</label>
                                <div class="file-upload">
                                    <i class="ph-bold ph-upload-simple" style="font-size: 1.5rem; color: var(--text-muted);"></i>
                                    <p style="margin-top: 5px; font-size: 0.9rem; color: var(--text-muted);">Click to browse or drag file here</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="form-section" style="border-bottom: none; margin-bottom: 0;">
                        <div class="checkbox-group">
                            <input type="checkbox" id="terms" required>
                            <label for="terms">I agree to the Terms and Conditions of admission and declare that all information provided is accurate and true.</label>
                        </div>
                        <div style="text-align: right; margin-top: 30px;">
                            <button type="submit" class="btn-primary" style="padding: 12px 30px; font-size: 1.05rem;">
                                Submit Application <i class="ph-bold ph-paper-plane-right"></i>
                            </button>
                        </div>
                    </div>
                    
                </form>
            </div>
        </div>
    </section>

    <section class="section-white">
        <div class="container">
            <div class="section-header text-center fade-up">
                <h2>Required Documents</h2>
                <p>Please ensure you have these documents ready at the time of interview.</p>
            </div>
            
            <div class="docs-list fade-up">
                <div class="doc-item">
                    <i class="ph-fill ph-identification-card"></i>
                    <div>
                        <h4 style="font-size: 1rem;">Birth Certificate</h4>
                        <span style="font-size: 0.85rem; color: var(--text-muted);">Original & Photocopy</span>
                    </div>
                </div>
                <div class="doc-item">
                    <i class="ph-fill ph-image"></i>
                    <div>
                        <h4 style="font-size: 1rem;">Passport Photos</h4>
                        <span style="font-size: 0.85rem; color: var(--text-muted);">4 Recent photographs</span>
                    </div>
                </div>
                <div class="doc-item">
                    <i class="ph-fill ph-address-book"></i>
                    <div>
                        <h4 style="font-size: 1rem;">Parent ID Proof</h4>
                        <span style="font-size: 0.85rem; color: var(--text-muted);">National ID / Passport</span>
                    </div>
                </div>
                <div class="doc-item">
                    <i class="ph-fill ph-certificate"></i>
                    <div>
                        <h4 style="font-size: 1rem;">Previous Record</h4>
                        <span style="font-size: 0.85rem; color: var(--text-muted);">Transfer Certificate (If any)</span>
                    </div>
                </div>
                <div class="doc-item">
                    <i class="ph-fill ph-first-aid-kit"></i>
                    <div>
                        <h4 style="font-size: 1rem;">Medical Record</h4>
                        <span style="font-size: 0.85rem; color: var(--text-muted);">Basic health fitness form</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section-cream">
        <div class="container">
            <div class="section-header text-center fade-up">
                <h2>Admission Dates</h2>
                <p>Important dates for the upcoming academic session</p>
            </div>
            
            <div class="dates-container fade-up">
                <div class="date-card">
                    <h4>Forms Available From</h4>
                    <div class="date-value">15 May</div>
                    <p style="font-size: 0.9rem; opacity: 0.9;">2026</p>
                </div>
                <div class="date-card secondary">
                    <h4>Last Date to Apply</h4>
                    <div class="date-value">10 Jun</div>
                    <p style="font-size: 0.9rem; color: var(--text-muted);">2026</p>
                </div>
                <div class="date-card secondary">
                    <h4>Interviews Begin</h4>
                    <div class="date-value">15 Jun</div>
                    <p style="font-size: 0.9rem; color: var(--text-muted);">2026</p>
                </div>
                <div class="date-card">
                    <h4>Classes Start</h4>
                    <div class="date-value">01 Jul</div>
                    <p style="font-size: 0.9rem; opacity: 0.9;">2026</p>
                </div>
            </div>
        </div>
    </section>

    <section class="section-white">
        <div class="container">
            <div class="section-header text-center fade-up">
                <h2>Frequently Asked Questions</h2>
                <p>Common questions about our admission process</p>
            </div>
            
            <div class="faq-list fade-up" style="max-width: 800px; margin: 0 auto;">
                <div class="faq-item">
                    <div class="faq-question">
                        What is the minimum age for admission to the Qaida course?
                        <i class="ph-bold ph-caret-down"></i>
                    </div>
                    <div class="faq-answer">
                        We accept students starting from the age of 5 years for the basic Qaida course.
                    </div>
                </div>
                <div class="faq-item">
                    <div class="faq-question">
                        Are interviews mandatory?
                        <i class="ph-bold ph-caret-down"></i>
                    </div>
                    <div class="faq-answer">
                        Yes, a brief interactive session is mandatory to understand the student's current level and recommend the appropriate course.
                    </div>
                </div>
                <div class="faq-item">
                    <div class="faq-question">
                        Can we pay the admission fee in installments?
                        <i class="ph-bold ph-caret-down"></i>
                    </div>
                    <div class="faq-answer">
                        The admission fee is a one-time payment. However, monthly tuition fees can be paid on a monthly or quarterly basis.
                    </div>
                </div>
            </div>
            
            <div class="contact-admissions fade-up">
                <i class="ph-fill ph-headset"></i>
                <h3 style="margin-bottom: 10px;">Need Help with Admissions?</h3>
                <p style="color: var(--text-muted); margin-bottom: 20px;">Our admissions team is here to guide you through the process.</p>
                <div style="display: flex; gap: 20px; justify-content: center; flex-wrap: wrap;">
                    <a href="tel:+1234567890" class="btn-primary"><i class="ph-fill ph-phone"></i> +1 234 567 890</a>
                    <a href="mailto:admissions@deeniyat.com" class="btn-secondary"><i class="ph-fill ph-envelope"></i> admissions@deeniyat.com</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->