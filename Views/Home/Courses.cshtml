@{
    ViewData["Title"] = "Courses";
}

<!-- Hero Banner -->
    <header class="section-cream" style="padding: 160px 0 80px;">
        <div class="container" style="text-align: center;">
            <div class="badge">ACADEMICS</div>
            <h1 style="font-size: 3.2rem; margin-bottom: 24px;">Browse Our Courses</h1>
            <p style="font-size: 1.1rem; color: var(--text-muted); max-width: 600px; margin: 0 auto;">From foundational Qaida to advanced Islamic Studies, find the perfect program tailored for your learning journey.</p>
        </div>
    </header>

    <!-- Course Grid -->
    <section class="section-white">
        <div class="container">
            <div class="course-grid">
                
                <!-- Qaida -->
                <div class="course-card">
                    <img src="../images/qaida.jpg" onerror="this.src='https://images.unsplash.com/photo-1584286595398-a59f21d313f5?auto=format&fit=crop&q=80&w=800';" alt="Qaida" class="course-image">
                    <div class="course-info">
                        <div class="course-header">
                            <h3 class="course-title">Qaida Foundation</h3>
                            <span class="course-fee">$50/mo</span>
                        </div>
                        <div class="course-meta">
                            <span><i class="ph-fill ph-clock"></i> 6 Months</span>
                            <span><i class="ph-fill ph-users"></i> Age 5-8</span>
                        </div>
                        <p class="course-description">The perfect starting point for young learners to master Arabic letters and pronunciation.</p>
                        <a href="#" class="btn-secondary" style="width: 100%;">Enroll Now</a>
                    </div>
                </div>

                <!-- Quran Reading -->
                <div class="course-card">
                    <img src="../images/quran.jpg" onerror="this.src='https://images.unsplash.com/photo-1609599006353-e629aaab31ce?auto=format&fit=crop&q=80&w=800';" alt="Quran Reading" class="course-image">
                    <div class="course-info">
                        <div class="course-header">
                            <h3 class="course-title">Quran Reading (Nazira)</h3>
                            <span class="course-fee">$60/mo</span>
                        </div>
                        <div class="course-meta">
                            <span><i class="ph-fill ph-clock"></i> 1-2 Years</span>
                            <span><i class="ph-fill ph-users"></i> Age 7+</span>
                        </div>
                        <p class="course-description">Learn to read the Holy Quran fluently with basic rules of pronunciation.</p>
                        <a href="#" class="btn-secondary" style="width: 100%;">Enroll Now</a>
                    </div>
                </div>

                <!-- Tajweed -->
                <div class="course-card">
                    <img src="../images/tajweed.jpg" onerror="this.src='https://images.unsplash.com/photo-1609599006353-e629aaab31ce?auto=format&fit=crop&q=80&w=800';" alt="Tajweed" class="course-image">
                    <div class="course-info">
                        <div class="course-header">
                            <h3 class="course-title">Advanced Tajweed</h3>
                            <span class="course-fee">$70/mo</span>
                        </div>
                        <div class="course-meta">
                            <span><i class="ph-fill ph-clock"></i> 1 Year</span>
                            <span><i class="ph-fill ph-users"></i> Age 10+</span>
                        </div>
                        <p class="course-description">Master the intricate rules of Tajweed to recite the Quran exactly as it was revealed.</p>
                        <a href="#" class="btn-secondary" style="width: 100%;">Enroll Now</a>
                    </div>
                </div>

                <!-- Hifz -->
                <div class="course-card">
                    <img src="../images/hifz.jpg" onerror="this.src='https://images.unsplash.com/photo-1584286595398-a59f21d313f5?auto=format&fit=crop&q=80&w=800';" alt="Hifz" class="course-image">
                    <div class="course-info">
                        <div class="course-header">
                            <h3 class="course-title">Hifz Program</h3>
                            <span class="course-fee">$100/mo</span>
                        </div>
                        <div class="course-meta">
                            <span><i class="ph-fill ph-clock"></i> 3-5 Years</span>
                            <span><i class="ph-fill ph-users"></i> Age 8-15</span>
                        </div>
                        <p class="course-description">A rigorous, rewarding program dedicated to the complete memorization of the Holy Quran.</p>
                        <a href="#" class="btn-secondary" style="width: 100%;">Enroll Now</a>
                    </div>
                </div>

                <!-- Islamic Studies -->
                <div class="course-card">
                    <img src="../images/islamic-studies.jpg" onerror="this.src='https://images.unsplash.com/photo-1601662528567-526cd06f6582?auto=format&fit=crop&q=80&w=800';" alt="Islamic Studies" class="course-image">
                    <div class="course-info">
                        <div class="course-header">
                            <h3 class="course-title">Islamic Studies</h3>
                            <span class="course-fee">$50/mo</span>
                        </div>
                        <div class="course-meta">
                            <span><i class="ph-fill ph-clock"></i> Ongoing</span>
                            <span><i class="ph-fill ph-users"></i> All Ages</span>
                        </div>
                        <p class="course-description">Comprehensive curriculum covering Seerah, Fiqh, Aqeedah, and Islamic history.</p>
                        <a href="#" class="btn-secondary" style="width: 100%;">Enroll Now</a>
                    </div>
                </div>

                <!-- Arabic Language -->
                <div class="course-card">
                    <img src="../images/arabic.jpg" onerror="this.src='https://images.unsplash.com/photo-1542468764-16a7f015b3c4?auto=format&fit=crop&q=80&w=800';" alt="Arabic Language" class="course-image">
                    <div class="course-info">
                        <div class="course-header">
                            <h3 class="course-title">Arabic Language</h3>
                            <span class="course-fee">$80/mo</span>
                        </div>
                        <div class="course-meta">
                            <span><i class="ph-fill ph-clock"></i> 2 Years</span>
                            <span><i class="ph-fill ph-users"></i> Teens & Adults</span>
                        </div>
                        <p class="course-description">Learn to speak, read, and understand Arabic to connect deeply with original texts.</p>
                        <a href="#" class="btn-secondary" style="width: 100%;">Enroll Now</a>
                    </div>
                </div>

                <!-- Weekend Classes -->
                <div class="course-card">
                    <img src="../images/weekend.jpg" onerror="this.src='https://ui-avatars.com/api/?name=weekend classes&background=a2ae40&color=fff&size=400';" alt="Weekend Classes" class="course-image">
                    <div class="course-info">
                        <div class="course-header">
                            <h3 class="course-title">Weekend Classes</h3>
                            <span class="course-fee">$40/mo</span>
                        </div>
                        <div class="course-meta">
                            <span><i class="ph-fill ph-clock"></i> Sat & Sun</span>
                            <span><i class="ph-fill ph-users"></i> Kids</span>
                        </div>
                        <p class="course-description">Designed for busy families. Covers Quran reading and basic Islamic studies on weekends.</p>
                        <a href="#" class="btn-secondary" style="width: 100%;">Enroll Now</a>
                    </div>
                </div>

                <!-- Online Classes -->
                <div class="course-card">
                    <img src="../images/online.jpg" onerror="this.src='https://ui-avatars.com/api/?name=online classes&background=a2ae40&color=fff&size=400';" alt="Online Classes" class="course-image">
                    <div class="course-info">
                        <div class="course-header">
                            <h3 class="course-title">Online Classes</h3>
                            <span class="course-fee">$60/mo</span>
                        </div>
                        <div class="course-meta">
                            <span><i class="ph-fill ph-clock"></i> Flexible</span>
                            <span><i class="ph-fill ph-users"></i> Global</span>
                        </div>
                        <p class="course-description">1-on-1 and group classes available virtually with our certified instructors worldwide.</p>
                        <a href="#" class="btn-secondary" style="width: 100%;">Enroll Now</a>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- Course Comparison Table -->
    <section class="section-cream">
        <div class="container">
            <div class="section-header">
                <h2>Compare Our Programs</h2>
                <p>Find the right fit for your educational goals.</p>
            </div>
            
            <div class="table-wrapper">
                <table class="comparison-table">
                    <thead>
                        <tr>
                            <th>Feature</th>
                            <th>Maktab / Evening</th>
                            <th>Weekend Program</th>
                            <th>Online 1-on-1</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>Class Size</strong></td>
                            <td>15-20 Students</td>
                            <td>15-20 Students</td>
                            <td>1 Student</td>
                        </tr>
                        <tr>
                            <td><strong>Schedule</strong></td>
                            <td>Mon-Fri (2 Hours)</td>
                            <td>Sat-Sun (3 Hours)</td>
                            <td>Flexible (Picked by you)</td>
                        </tr>
                        <tr>
                            <td><strong>Interactive App Access</strong></td>
                            <td><i class="ph-bold ph-check" style="color: var(--primary);"></i> Included</td>
                            <td><i class="ph-bold ph-check" style="color: var(--primary);"></i> Included</td>
                            <td><i class="ph-bold ph-check" style="color: var(--primary);"></i> Included</td>
                        </tr>
                        <tr>
                            <td><strong>Monthly Assessments</strong></td>
                            <td><i class="ph-bold ph-check" style="color: var(--primary);"></i> Yes</td>
                            <td><i class="ph-bold ph-check" style="color: var(--primary);"></i> Yes</td>
                            <td><i class="ph-bold ph-check" style="color: var(--primary);"></i> Yes</td>
                        </tr>
                        <tr>
                            <td><strong>Best For</strong></td>
                            <td>Consistent daily progress</td>
                            <td>Busy school schedules</td>
                            <td>Personalized pacing</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="section-white">
        <div class="container">
            <div class="section-header">
                <h2>Frequently Asked Questions</h2>
            </div>
            
            <div class="faq-grid">
                <div class="faq-item">
                    <div class="faq-question">What is the admission process?</div>
                    <div class="faq-answer">Simply click on "Enroll Now" for your desired course, fill out the basic registration form, and our administration will contact you within 24 hours to finalize placement and schedule.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-question">Do you offer financial aid?</div>
                    <div class="faq-answer">Yes, Deeniyat is committed to making education accessible to everyone. Please contact our office to discuss available scholarships and fee waivers.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-question">Are the online classes live or pre-recorded?</div>
                    <div class="faq-answer">All our online classes are conducted live by certified teachers to ensure interactivity, real-time feedback, and proper pronunciation correction.</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Call To Action -->
    <section class="section-cream" style="text-align: center; padding: 60px 0;">
        <div class="container">
            <h2 style="font-size: 2.5rem; margin-bottom: 20px;">Ready to Start Learning?</h2>
            <p style="color: var(--text-muted); font-size: 1.1rem; margin-bottom: 30px; max-width: 600px; margin-left: auto; margin-right: auto;">Join thousands of students who are building a strong foundation in Islamic and modern education today.</p>
            <a href="#" class="btn-primary" style="font-size: 1.1rem; padding: 14px 32px;">Create an Account</a>
        </div>
    </section>
