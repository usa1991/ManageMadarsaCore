@{
    ViewData["Title"] = "Events";
}

<header class="hero section-cream">
        <div class="container hero-grid" style="text-align: center; display: block;">
            <div class="badge fade-up">CAMPUS LIFE</div>
            <h1 class="fade-up">Events & Calendar</h1>
            <p class="fade-up" style="max-width: 600px; margin: 0 auto 30px;">Discover what's happening at Deeniyat Madrasa. From academic competitions to festive celebrations, stay updated with our vibrant community.</p>
        </div>
    </header>

