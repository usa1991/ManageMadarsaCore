@{
    ViewData["Title"] = "FAQ";
}

<header class="hero section-cream" style="padding-bottom: 80px;">
        <div class="container hero-grid" style="text-align: center; display: block;">
            <div class="badge fade-up">HELP CENTER</div>
            <h1 class="fade-up">Frequently Asked Questions</h1>
            <p class="fade-up" style="max-width: 600px; margin: 0 auto;">Find answers to common questions about admissions, fees, courses, and daily life at Deeniyat.</p>
        </div>
    </header>

    <div class="container fade-up">
        <div class="faq-search-container">
            <div class="faq-search-box">
                <i class="ph-bold ph-magnifying-glass"></i>
                <input type="text" id="faqSearchInput" placeholder="Search for a question...">
            </div>
        </div>
    </div>

    <section class="section-white" style="padding-top: 20px;">
        <div class="container">
            
            <div class="faq-categories fade-up">
                <button class="faq-category-btn active" data-filter="all">All</button>
                <button class="faq-category-btn" data-filter="admissions">Admissions</button>
                <button class="faq-category-btn" data-filter="fees">Fees</button>
                <button class="faq-category-btn" data-filter="courses">Courses</button>
                <button class="faq-category-btn" data-filter="teachers">Teachers</button>
                <button class="faq-category-btn" data-filter="exams">Exams</button>
                <button class="faq-category-btn" data-filter="transport">Transport</button>
                <button class="faq-category-btn" data-filter="prayer">Prayer</button>
                <button class="faq-category-btn" data-filter="contact">Contact</button>
            </div>
            
            <div class="faq-list fade-up" id="faqContainer" style="max-width: 800px; margin: 0 auto;">
                
                <!-- Admissions -->
                <div class="faq-item" data-category="admissions">
                    <div class="faq-question">
                        What is the minimum age for admission to the Qaida course?
                        <i class="ph-bold ph-caret-down"></i>
                    </div>
                    <div class="faq-answer">
                        We accept students starting from the age of 5 years for the basic Qaida course.
                    </div>
                </div>
                <div class="faq-item" data-category="admissions">
                    <div class="faq-question">
                        Are interviews mandatory for admission?
                        <i class="ph-bold ph-caret-down"></i>
                    </div>
                    <div class="faq-answer">
                        Yes, a brief interactive session is mandatory to understand the student's current level and recommend the appropriate course.
                    </div>
                </div>

                <!-- Fees -->
                <div class="faq-item" data-category="fees">
                    <div class="faq-question">
                        Can we pay the admission fee in installments?
                        <i class="ph-bold ph-caret-down"></i>
                    </div>
                    <div class="faq-answer">
                        The admission fee is a one-time payment. However, monthly tuition fees can be paid on a monthly or quarterly basis.
                    </div>
                </div>
                <div class="faq-item" data-category="fees">
                    <div class="faq-question">
                        Do you offer scholarships or financial aid?
                        <i class="ph-bold ph-caret-down"></i>
                    </div>
                    <div class="faq-answer">
                        Yes, we have a dedicated scholarship fund for deserving and underprivileged students. You can apply for this during the admission process.
                    </div>
                </div>

                <!-- Courses -->
                <div class="faq-item" data-category="courses">
                    <div class="faq-question">
                        What is the duration of the Hifz course?
                        <i class="ph-bold ph-caret-down"></i>
                    </div>
                    <div class="faq-answer">
                        The Hifz course typically takes 3 to 4 years to complete, depending entirely on the individual student's memorization capability and dedication.
                    </div>
                </div>
                <div class="faq-item" data-category="courses">
                    <div class="faq-question">
                        Do you offer online classes?
                        <i class="ph-bold ph-caret-down"></i>
                    </div>
                    <div class="faq-answer">
                        Yes! We offer a fully functional online learning platform for students who cannot attend the physical campus.
                    </div>
                </div>

                <!-- Teachers -->
                <div class="faq-item" data-category="teachers">
                    <div class="faq-question">
                        What are the qualifications of your teachers?
                        <i class="ph-bold ph-caret-down"></i>
                    </div>
                    <div class="faq-answer">
                        All our teachers are certified Alims, Qaris, and Hafiz-e-Quran from recognized Islamic universities, possessing years of teaching experience.
                    </div>
                </div>

                <!-- Exams -->
                <div class="faq-item" data-category="exams">
                    <div class="faq-question">
                        How often are examinations conducted?
                        <i class="ph-bold ph-caret-down"></i>
                    </div>
                    <div class="faq-answer">
                        We conduct formal examinations twice a year (Half-yearly and Annual), along with monthly progress assessments.
                    </div>
                </div>

                <!-- Transport -->
                <div class="faq-item" data-category="transport">
                    <div class="faq-question">
                        Is transport facility available for all areas?
                        <i class="ph-bold ph-caret-down"></i>
                    </div>
                    <div class="faq-answer">
                        Our transport network covers a 15km radius around the campus. Please contact the admin office with your specific location to confirm availability.
                    </div>
                </div>

                <!-- Prayer -->
                <div class="faq-item" data-category="prayer">
                    <div class="faq-question">
                        Are daily prayers offered in the campus?
                        <i class="ph-bold ph-caret-down"></i>
                    </div>
                    <div class="faq-answer">
                        Absolutely. All congregational prayers that fall within campus hours (such as Zuhr and Asr) are performed in the campus Prayer Hall.
                    </div>
                </div>

                <!-- Contact -->
                <div class="faq-item" data-category="contact">
                    <div class="faq-question">
                        Who do I contact in case of an emergency?
                        <i class="ph-bold ph-caret-down"></i>
                    </div>
                    <div class="faq-answer">
                        Parents can directly call the admin office hotlines (+1 234 567 890) which are active during all campus hours for any emergencies.
                    </div>
                </div>
                
            </div>
            
            <div id="noResults" class="faq-no-results">
                No FAQs found matching your search criteria.
            </div>
            
            <div class="need-help-section fade-up">
                <h2>Still have questions?</h2>
                <p>If you couldn't find the answer to your question in the FAQ, feel free to reach out to us.</p>
                <a href="contact.html" class="btn-primary" style="padding: 12px 30px; font-size: 1.05rem;"><i class="ph-fill ph-chat-circle-text"></i> Contact Us</a>
            </div>

        </div>
    </section>

    <!-- Footer -->
    

    <!-- Footer -->

<script>
        // Navbar Scroll Effect
        window.addEventListener('scroll', () => {
            const navbar = document.querySelector('.navbar');
            if (window.scrollY > 10) {
                navbar.classList.add('scrolled');
            } else {
                navbar.classList.remove('scrolled');
            }
        });

        // Initialize Anime.js animations
        document.addEventListener('DOMContentLoaded', () => {
            anime({
                targets: '.fade-up',
                translateY: [30, 0],
                opacity: [0, 1],
                duration: 800,
                easing: 'easeOutCubic',
                delay: anime.stagger(150, {start: 100})
            });
        });

        // FAQ Filtering & Search Logic
        const searchInput = document.getElementById('faqSearchInput');
        const filterBtns = document.querySelectorAll('.faq-category-btn');
        const faqItems = document.querySelectorAll('.faq-item');
        const noResults = document.getElementById('noResults');

        function filterFAQs() {
            const searchTerm = searchInput.value.toLowerCase();
            const activeFilter = document.querySelector('.faq-category-btn.active').getAttribute('data-filter');
            let visibleCount = 0;

            faqItems.forEach(item => {
                const text = item.innerText.toLowerCase();
                const category = item.getAttribute('data-category');
                
                const matchesSearch = text.includes(searchTerm);
                const matchesFilter = activeFilter === 'all' || category === activeFilter;

                if (matchesSearch && matchesFilter) {
                    item.style.display = 'block';
                    visibleCount++;
                } else {
                    item.style.display = 'none';
                    item.classList.remove('active'); // Close hidden accordions
                }
            });

            if (visibleCount === 0) {
                noResults.style.display = 'block';
            } else {
                noResults.style.display = 'none';
            }
        }

        searchInput.addEventListener('input', filterFAQs);

        filterBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                filterBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                filterFAQs();
            });
        });

        // FAQ Accordion Toggle
        document.querySelectorAll('.faq-question').forEach(question => {
            question.addEventListener('click', () => {
                const item = question.parentElement;
                const isActive = item.classList.contains('active');
                
                // Close all other FAQs
                document.querySelectorAll('.faq-item').forEach(faq => {
                    faq.classList.remove('active');
                });
                
                // Open clicked FAQ if it wasn't active
                if (!isActive) {
                    item.classList.add('active');
                }
            });
        });
    </script>
