@{
    ViewData["Title"] = "Features";
}

<!-- Promotional Swiper Banner -->
    
    <!-- Page Header -->
    <section style="padding: 100px 0 60px; background-color: #fcfcfc; text-align: center; border-bottom: 1px solid #f1f1f1;">
        <div class="container fade-up">
            <h1 style="font-size: 3rem; font-weight: 700; color: #222; margin-bottom: 15px;">Features</h1>
            <p style="color: #666; font-size: 1.2rem; max-width: 600px; margin: 0 auto;">Explore the powerful tools ManageMadarsa offers to simplify and streamline your institution.</p>
        </div>
    </section>

    <!-- Feature 1 -->
    <section class="feature-showcase-section">
        <div class="container feature-showcase-container fade-up">
            <div class="feature-showcase-content">
                <div class="feature-badge"><i class="ph-bold ph-sliders"></i> Administration</div>
                <h2 class="feature-showcase-title">Full Control</h2>
                <p class="feature-showcase-desc">Manage students, teachers, classes, and fees from one clean dashboard. Every record organised, accessible, and always up to date.</p>
                <div class="feature-bullets">
                    <div class="feature-bullet"><i class="ph-bold ph-check-circle"></i> Student & teacher management</div>
                    <div class="feature-bullet"><i class="ph-bold ph-check-circle"></i> Admin staff access & permissions</div>
                    <div class="feature-bullet"><i class="ph-bold ph-check-circle"></i> Messaging between staff & teachers</div>
                    <div class="feature-bullet"><i class="ph-bold ph-check-circle"></i> Class & fees management</div>
                </div>
            </div>
            <div class="feature-showcase-image">
                <!-- Replace 'src' with your actual video path e.g. '../videos/demo.mp4' -->
                <video width="100%" autoplay loop muted playsinline style="border-radius: 12px; box-shadow: 0 20px 40px rgba(0,0,0,0.08); background: #fcfcfc;">
                    <source src="../images/1920x1080.mp4" type="video/mp4">
                    Your browser does not support the video tag.
                </video>
            </div>
        </div>
    </section>

    <!-- Feature 2 -->
    <section class="feature-showcase-section feature-showcase-reverse">
        <div class="container feature-showcase-container fade-up">
            <div class="feature-showcase-content">
                <div class="feature-badge"><i class="ph-bold ph-chart-bar"></i> Data & Reporting</div>
                <h2 class="feature-showcase-title">Your Data. Crystal Clear.</h2>
                <p class="feature-showcase-desc">ManageMadarsa turns numbers into visual charts and graphs — so you can spot trends and present to your committee without digging through spreadsheets.</p>
                <div class="feature-bullets">
                    <div class="feature-bullet"><i class="ph-bold ph-check-circle"></i> Attendance charts & trends</div>
                    <div class="feature-bullet"><i class="ph-bold ph-check-circle"></i> Student performance graphs</div>
                    <div class="feature-bullet"><i class="ph-bold ph-check-circle"></i> Fee collection overviews</div>
                    <div class="feature-bullet"><i class="ph-bold ph-check-circle"></i> Committee-ready visual reports</div>
                </div>
            </div>
            <div class="feature-showcase-image">
                <!-- Replace 'src' with your actual video path e.g. '../videos/demo.mp4' -->
                <video width="100%" autoplay loop muted playsinline style="border-radius: 12px; box-shadow: 0 20px 40px rgba(0,0,0,0.08); background: #fcfcfc;">
                    <source src="../images/1920x1080.mp4" type="video/mp4">
                    Your browser does not support the video tag.
                </video>
            </div>
        </div>
    </section>

    <!-- Feature 3 -->
    <section class="feature-showcase-section">
        <div class="container feature-showcase-container fade-up">
            <div class="feature-showcase-content">
                <div class="feature-badge"><i class="ph-bold ph-file-text"></i> Reports</div>
                <h2 class="feature-showcase-title">Every Report. One Click Away</h2>
                <p class="feature-showcase-desc">Generate instant summaries covering attendance, fees, incidents, and more. Download as PDF or view on screen — formatted and ready to share.</p>
                <div class="feature-bullets">
                    <div class="feature-bullet"><i class="ph-bold ph-check-circle"></i> Fee & financial summaries</div>
                    <div class="feature-bullet"><i class="ph-bold ph-check-circle"></i> Attendance & register reports</div>
                    <div class="feature-bullet"><i class="ph-bold ph-check-circle"></i> Incident & location reports</div>
                    <div class="feature-bullet"><i class="ph-bold ph-check-circle"></i> End of term PDF & email reports</div>
                </div>
            </div>
            <div class="feature-showcase-image">
                <!-- Replace 'src' with your actual video path e.g. '../videos/demo.mp4' -->
                <video width="100%" autoplay loop muted playsinline style="border-radius: 12px; box-shadow: 0 20px 40px rgba(0,0,0,0.08); background: #fcfcfc;">
                    <source src="../images/1920x1080.mp4" type="video/mp4">
                    Your browser does not support the video tag.
                </video>
            </div>
        </div>
<!-- made by "He is The Usman (≖⩊≖)" -->
    </section>

    <!-- Feature 4 -->
    <section class="feature-showcase-section feature-showcase-reverse">
        <div class="container feature-showcase-container fade-up">
            <div class="feature-showcase-content">
                <div class="feature-badge"><i class="ph-bold ph-palette"></i> Themes</div>
                <h2 class="feature-showcase-title">Make It Yours</h2>
                <p class="feature-showcase-desc">Every institution has its own way of working. ManageMadarsa lets each staff member customise their experience — preferences are saved individually so everyone sees the interface that works best for them.</p>
                <div class="feature-bullets">
                    <div class="feature-bullet"><i class="ph-bold ph-check-circle"></i> Per-user theme preferences</div>
                    <div class="feature-bullet"><i class="ph-bold ph-check-circle"></i> Role-based dashboard views</div>
                    <div class="feature-bullet"><i class="ph-bold ph-check-circle"></i> Saved preferences across sessions</div>
                    <div class="feature-bullet"><i class="ph-bold ph-check-circle"></i> Works on every device & browser</div>
                </div>
            </div>
            <div class="feature-showcase-image">
                <!-- Replace 'src' with your actual video path e.g. '../videos/demo.mp4' -->
                <video width="100%" autoplay loop muted playsinline style="border-radius: 12px; box-shadow: 0 20px 40px rgba(0,0,0,0.08); background: #fcfcfc;">
                    <source src="../images/1920x1080.mp4" type="video/mp4">
                    Your browser does not support the video tag.
                </video>
            </div>
        </div>
    </section>