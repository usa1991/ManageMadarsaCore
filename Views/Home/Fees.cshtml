@{
    ViewData["Title"] = "Fee Structure";
}

<!-- Hero Banner -->
    <header class="section-cream" style="padding: 160px 0 80px;">
        <div class="container" style="text-align: center;">
            <div class="badge">AFFORDABLE EDUCATION</div>
            <h1 style="font-size: 3.2rem; margin-bottom: 24px;">Fee Structure</h1>
            <p style="font-size: 1.1rem; color: var(--text-muted); max-width: 600px; margin: 0 auto 30px;">Transparent pricing with flexible payment plans and scholarships to ensure quality Islamic education is accessible to everyone.</p>
            <div class="hero-actions" style="justify-content: center;">
                <a href="#apply" class="btn-primary">Apply Now</a>
                <a href="#" class="btn-outline"><i class="ph-bold ph-download-simple"></i> Download Fee PDF</a>
            </div>
        </div>
    </header>

    <!-- Core Fees Section -->
    <section class="section-white">
        <div class="container">
            <div class="section-header">
                <h2>Standard Fees</h2>
                <p>Our baseline academic fees for regular programs.</p>
            </div>
            
            <div class="fee-grid">
                <!-- Admission Fee -->
                <div class="fee-card">
                    <i class="ph-fill ph-file-text fee-icon"></i>
                    <h3 class="fee-title">Admission Fee</h3>
                    <div class="fee-price">$50 <span>/ one-time</span></div>
                    <p class="fee-desc">Non-refundable registration fee required at the time of initial enrollment. Covers administrative processing.</p>
                </div>
                
                <!-- Monthly Fee -->
                <div class="fee-card">
                    <i class="ph-fill ph-calendar-check fee-icon"></i>
                    <h3 class="fee-title">Monthly Tuition</h3>
                    <div class="fee-price">$40 <span>/ month</span></div>
                    <p class="fee-desc">Standard monthly fee for regular courses (Qaida, Quran, Tajweed). Excludes specialized Hifz programs.</p>
                </div>
                
                <!-- Books & Materials -->
                <div class="fee-card">
                    <i class="ph-fill ph-books fee-icon"></i>
                    <h3 class="fee-title">Books & Materials</h3>
                    <div class="fee-price">$30 <span>/ year</span></div>
                    <p class="fee-desc">Annual fee covering textbooks, notebooks, syllabus planners, and digital learning resources.</p>
                </div>
                
                <!-- Uniform -->
                <div class="fee-card">
                    <i class="ph-fill ph-t-shirt fee-icon"></i>
                    <h3 class="fee-title">Uniform Kit</h3>
                    <div class="fee-price">$25 <span>/ set</span></div>
                    <p class="fee-desc">Standard Deeniyat uniform (Kurta/Jubbah & Cap for boys, Abaya/Scarf for girls). Recommended purchase.</p>
                </div>
                
                <!-- Transport -->
                <div class="fee-card">
                    <i class="ph-fill ph-bus fee-icon"></i>
                    <h3 class="fee-title">Transportation</h3>
                    <div class="fee-price">$60 <span>/ month</span></div>
                    <p class="fee-desc">Optional pick-up and drop-off service. Price may vary based on distance from the Madarsa.</p>
                </div>
                
                <!-- Hostel -->
                <div class="fee-card">
                    <i class="ph-fill ph-house-line fee-icon"></i>
                    <h3 class="fee-title">Hostel & Boarding</h3>
                    <div class="fee-price">$150 <span>/ month</span></div>
                    <p class="fee-desc">Full boarding facility including 3 meals, laundry, and supervised study sessions for Hifz students.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Payment Plans & Discounts -->
    <section class="section-cream">
        <div class="container">
            <div class="section-header">
                <h2>Flexible Options</h2>
                <p>We make it easier for families to manage their educational investments.</p>
            </div>

            <div class="feature-grid" style="grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));">
                <!-- Payment Plans -->
                <div class="feature-card">
                    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px;">
                        <i class="ph-fill ph-credit-card" style="font-size: 2rem; color: var(--primary);"></i>
                        <h3 style="margin: 0; font-size: 1.5rem;">Installment Plans</h3>
                    </div>
                    <p style="color: var(--text-muted); margin-bottom: 20px;">Pay the annual fees in manageable chunks rather than all at once.</p>
                    <ul class="info-list">
                        <li><span>Quarterly Plan</span> <strong>4 payments / year</strong></li>
                        <li><span>Bi-Annual Plan</span> <strong>2 payments / year (5% Off)</strong></li>
                        <li><span>Annual Plan</span> <strong>1 payment / year (10% Off)</strong></li>
                    </ul>
                </div>

                <!-- Discounts -->
                <div class="feature-card">
                    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px;">
                        <i class="ph-fill ph-users-three" style="font-size: 2rem; color: var(--primary);"></i>
                        <h3 style="margin: 0; font-size: 1.5rem;">Sibling Discounts</h3>
                    </div>
                    <p style="color: var(--text-muted); margin-bottom: 20px;">We offer generous discounts for families enrolling multiple children.</p>
                    <ul class="info-list">
                        <li><span>1st Child</span> <strong>Standard Fee</strong></li>
                        <li><span>2nd Child</span> <strong>15% Discount</strong></li>
                        <li><span>3rd Child (or more)</span> <strong>25% Discount</strong></li>
                    </ul>
                </div>

                <!-- Scholarships -->
                <div class="feature-card">
                    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px;">
                        <i class="ph-fill ph-student" style="font-size: 2rem; color: var(--primary);"></i>
                        <h3 style="margin: 0; font-size: 1.5rem;">Scholarships</h3>
                    </div>
                    <p style="color: var(--text-muted); margin-bottom: 20px;">No student should be denied education due to financial constraints.</p>
                    <ul class="info-list">
                        <li><span>Orphan Support</span> <strong>100% Free</strong></li>
                        <li><span>Zakat Eligible</span> <strong>Up to 100% Funded</strong></li>
                        <li><span>Merit Scholarship</span> <strong>Up to 50% Off (Hifz)</strong></li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Payment Methods & FAQ -->
    <section class="section-white">
        <div class="container">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px;">
                <!-- Payment Methods -->
                <div>
                    <h2 style="font-size: 2rem; margin-bottom: 24px;">Accepted Payment Methods</h2>
                    <p style="color: var(--text-muted); margin-bottom: 30px;">We accept various modern payment methods for your convenience.</p>
                    
                    <div class="payment-grid">
                        <div class="payment-method">
                            <i class="ph-fill ph-bank" style="font-size: 1.5rem; color: var(--primary);"></i>
                            <span style="font-weight: 500;">Bank Transfer (ACH)</span>
                        </div>
                        <div class="payment-method">
                            <i class="ph-fill ph-credit-card" style="font-size: 1.5rem; color: var(--primary);"></i>
                            <span style="font-weight: 500;">Credit / Debit Cards</span>
                        </div>
                        <div class="payment-method">
                            <i class="ph-fill ph-device-mobile" style="font-size: 1.5rem; color: var(--primary);"></i>
                            <span style="font-weight: 500;">Mobile Wallets (Apple/Google Pay)</span>
                        </div>
                        <div class="payment-method">
                            <i class="ph-fill ph-money" style="font-size: 1.5rem; color: var(--primary);"></i>
                            <span style="font-weight: 500;">Cash (at Office only)</span>
                        </div>
                    </div>
                </div>

                <!-- Fees FAQ -->
                <div>
                    <h2 style="font-size: 2rem; margin-bottom: 24px;">Fees FAQ</h2>
                    
                    <div class="faq-item">
                        <div class="faq-question">Are fees refundable if a student leaves? <i class="ph-bold ph-caret-down"></i></div>
                        <div class="faq-answer">Admission fees are strictly non-refundable. Monthly tuition fees are non-refundable for the current month, but advance payments for future months will be refunded entirely if a 30-day notice is given.</div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-question">When is the monthly fee due? <i class="ph-bold ph-caret-down"></i></div>
                        <div class="faq-answer">Fees are due by the 5th of every calendar month. Late payments may incur a small administrative charge unless prior arrangements are made with the management.</div>
                    </div>
                    <div class="faq-item">
                        <div class="faq-question">How do I apply for financial aid? <i class="ph-bold ph-caret-down"></i></div>
                        <div class="faq-answer">You can download the Zakat & Financial Aid form from our student portal or request a physical copy at the office. Applications take 1-2 weeks to process and are handled with strict confidentiality.</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Call to Action -->
    <section id="apply" class="section-cream" style="padding: 80px 0; text-align: center;">
        <div class="container">
            <h2 style="font-size: 2.5rem; margin-bottom: 20px;">Ready to Start Learning?</h2>
            <p style="color: var(--text-muted); font-size: 1.1rem; max-width: 600px; margin: 0 auto 30px;">
                Secure your spot in our upcoming batch today. The application process only takes a few minutes.
            </p>
            <a href="#" class="btn-primary" style="font-size: 1.1rem; padding: 14px 32px;">Apply Now <i class="ph-bold ph-arrow-right"></i></a>
        </div>
    </section>

<script>
        // Simple FAQ Accordion Toggle
        document.querySelectorAll('.faq-question').forEach(item => {
            item.addEventListener('click', event => {
                const answer = item.nextElementSibling;
                const icon = item.querySelector('i');
                const isOpen = answer.style.display === 'block';
                
                // Close all
                document.querySelectorAll('.faq-answer').forEach(ans => ans.style.display = 'none');
                document.querySelectorAll('.faq-question i').forEach(i => i.style.transform = 'rotate(0deg)');
                
                if (!isOpen) {
                    answer.style.display = 'block';
                    icon.style.transform = 'rotate(180deg)';
                }
            })
        });
    </script>
