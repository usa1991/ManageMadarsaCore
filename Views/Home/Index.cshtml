@{
    ViewData["Title"] = "Index";
}

<header class="hero-home">
        <div class="container hero-home-grid">
            <div class="hero-home-text fade-up">
                <div class="badge" style="margin-bottom: 20px;">WELCOME TO DEENIYAT</div>
                <h1>Quality Islamic Education for Every Child</h1>
                <p>Empowering the next generation with knowledge, wisdom, and core Islamic values in a nurturing, modern environment.</p>
                <div class="hero-home-actions">
                    <a href="/Home/Admissions" class="btn-primary">Apply Now</a>
                    <a href="/Home/Courses" class="btn-secondary">Explore Courses</a>
                </div>
            </div>
            <div class="hero-home-img fade-up" style="animation-delay: 0.2s;">
                <img src="https://placehold.co/800x600/a2ae40/ffffff?text=Students+Studying+Quran" alt="Students studying Quran">
            </div>
        </div>
    </header>

    <section class="stats-section">
        <div class="container">
            <div class="stats-grid">
                <div class="stat-item fade-up">
                    <h3 class="counter" data-target="500">0</h3>
                    <p>Students</p>
                </div>
                <div class="stat-item fade-up" style="animation-delay: 0.1s;">
                    <h3 class="counter" data-target="30">0</h3>
                    <p>Teachers</p>
                </div>
                <div class="stat-item fade-up" style="animation-delay: 0.2s;">
                    <h3 class="counter" data-target="10">0</h3>
                    <p>Years</p>
                </div>
                <div class="stat-item fade-up" style="animation-delay: 0.3s;">
                    <h3 class="counter" data-target="15">0</h3>
                    <p>Courses</p>
                </div>
            </div>
        </div>
    </section>

    <section class="section-cream" style="padding-top: 100px;">
        <div class="container">
            <div class="section-header fade-up">
                <h2>Why Choose Us</h2>
                <p>We provide a balanced approach to education, combining traditional Islamic teachings with modern methodologies.</p>
            </div>
            
            <div class="features-grid">
                <div class="feature-box fade-up">
                    <i class="ph-fill ph-chalkboard-teacher"></i>
                    <h3>Qualified Teachers</h3>
                    <p>Our educators are highly qualified scholars dedicated to nurturing students with knowledge and compassion.</p>
                </div>
                <div class="feature-box fade-up" style="animation-delay: 0.1s;">
                    <i class="ph-fill ph-desktop"></i>
                    <h3>Modern Learning</h3>
                    <p>We integrate technology and modern teaching techniques to make learning engaging and effective.</p>
                </div>
                <div class="feature-box fade-up" style="animation-delay: 0.2s;">
                    <i class="ph-fill ph-book-open"></i>
                    <h3>Islamic Values</h3>
                    <p>Core Islamic principles and ethics are woven into every aspect of our curriculum and environment.</p>
                </div>
                <div class="feature-box fade-up" style="animation-delay: 0.3s;">
                    <i class="ph-fill ph-wallet"></i>
                    <h3>Affordable Education</h3>
                    <p>Quality education should be accessible to all. We offer structured and reasonable fee plans.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="section-white">
        <div class="container">
            <div class="section-header fade-up">
                <h2>Popular Courses</h2>
                <p>Discover our most sought-after programs designed for various age groups and learning levels.</p>
            </div>
            
            <div class="courses-preview-grid">
                <!-- Course 1 -->
                <div class="course-card fade-up">
                    <div class="course-img">
                        <img src="https://placehold.co/600x400/eaeaea/888888?text=Quran+Nazira" alt="Quran Nazira">
                        <span class="course-badge">Beginner</span>
                    </div>
                    <div class="course-content">
                        <h3>Quran Nazira (Reading)</h3>
                        <p>Learn to read the Holy Quran with proper Tajweed rules from the basics.</p>
                        <a href="/Home/Courses" class="btn-secondary" style="width: 100%; text-align: center; margin-top: 15px;">View Details</a>
                    </div>
                </div>
                <!-- Course 2 -->
                <div class="course-card fade-up" style="animation-delay: 0.1s;">
                    <div class="course-img">
                        <img src="https://placehold.co/600x400/eaeaea/888888?text=Hifz-ul-Quran" alt="Hifz-ul-Quran">
                        <span class="course-badge">Advanced</span>
                    </div>
                    <div class="course-content">
                        <h3>Hifz-ul-Quran</h3>
                        <p>Memorization of the Holy Quran with a structured and supportive methodology.</p>
                        <a href="/Home/Courses" class="btn-secondary" style="width: 100%; text-align: center; margin-top: 15px;">View Details</a>
                    </div>
                </div>
                <!-- Course 3 -->
                <div class="course-card fade-up" style="animation-delay: 0.2s;">
                    <div class="course-img">
                        <img src="https://placehold.co/600x400/eaeaea/888888?text=Islamic+Studies" alt="Islamic Studies">
                        <span class="course-badge">Intermediate</span>
                    </div>
                    <div class="course-content">
                        <h3>Islamic Studies</h3>
                        <p>Comprehensive knowledge of Fiqh, Seerah, and Hadith for daily life.</p>
                        <a href="/Home/Courses" class="btn-secondary" style="width: 100%; text-align: center; margin-top: 15px;">View Details</a>
                    </div>
                </div>
                <!-- Course 4 -->
                <div class="course-card fade-up">
                    <div class="course-img">
                        <img src="https://placehold.co/600x400/eaeaea/888888?text=Arabic+Language" alt="Arabic Language">
                        <span class="course-badge">All Levels</span>
                    </div>
                    <div class="course-content">
                        <h3>Arabic Language</h3>
                        <p>Master the language of the Quran to understand its profound meanings directly.</p>
                        <a href="/Home/Courses" class="btn-secondary" style="width: 100%; text-align: center; margin-top: 15px;">View Details</a>
                    </div>
                </div>
                <!-- Course 5 -->
                <div class="course-card fade-up" style="animation-delay: 0.1s;">
                    <div class="course-img">
                        <img src="https://placehold.co/600x400/eaeaea/888888?text=Tafseer" alt="Tafseer">
                        <span class="course-badge">Advanced</span>
                    </div>
                    <div class="course-content">
                        <h3>Tafseer (Exegesis)</h3>
                        <p>In-depth study and explanation of the Quranic verses and their contexts.</p>
                        <a href="/Home/Courses" class="btn-secondary" style="width: 100%; text-align: center; margin-top: 15px;">View Details</a>
                    </div>
                </div>
                <!-- Course 6 -->
                <div class="course-card fade-up" style="animation-delay: 0.2s;">
                    <div class="course-img">
                        <img src="https://placehold.co/600x400/eaeaea/888888?text=Tajweed+Intensive" alt="Tajweed Intensive">
                        <span class="course-badge">Intermediate</span>
                    </div>
                    <div class="course-content">
                        <h3>Tajweed Intensive</h3>
                        <p>Perfect your pronunciation and recitation rules over a focused period.</p>
                        <a href="/Home/Courses" class="btn-secondary" style="width: 100%; text-align: center; margin-top: 15px;">View Details</a>
                    </div>
                </div>
            </div>
            
            <div style="text-align: center; margin-top: 40px;">
                <a href="/Home/Courses" class="btn-primary fade-up">View All Courses</a>
            </div>
        </div>
    </section>

    <section class="section-cream">
        <div class="container">
            <div class="hero-home-grid">
                <div>
                    <div class="section-header" style="text-align: left;">
                        <h2 class="fade-up">Latest Announcements</h2>
                        <p class="fade-up">Stay updated with the latest news, events, and notices from Deeniyat Madrasa.</p>
                    </div>
                    
                    <div class="announcements-list">
                        <div class="announcement-item fade-up">
                            <div class="announcement-date">
                                <span class="day">15</span>
                                <span class="month">Aug</span>
                            </div>
                            <div class="announcement-content">
                                <h4>Admissions Open for 2026</h4>
                                <p>Enrollments for the upcoming academic year have officially begun.</p>
                            </div>
                        </div>
                        <div class="announcement-item fade-up" style="animation-delay: 0.1s;">
                            <div class="announcement-date" style="background: var(--primary-light); color: var(--primary);">
                                <span class="day">01</span>
                                <span class="month">Sep</span>
                            </div>
                            <div class="announcement-content">
                                <h4>Ramadan Special Classes</h4>
                                <p>Join our special intensive Quran courses during the blessed month.</p>
                            </div>
                        </div>
                        <div class="announcement-item fade-up" style="animation-delay: 0.2s;">
                            <div class="announcement-date">
                                <span class="day">20</span>
                                <span class="month">Oct</span>
                            </div>
                            <div class="announcement-content">
                                <h4>Holiday Notice: Eid-ul-Fitr</h4>
                                <p>The Madrasa will remain closed for one week to celebrate Eid.</p>
                            </div>
                        </div>
                    </div>
                    
                    <a href="/Home/News" class="btn-secondary fade-up" style="margin-top: 30px; display: inline-block;">View All News</a>
                </div>
                
                <div class="fade-up" style="padding-left: 20px;">
                    <img src="https://placehold.co/600x600/a2ae40/ffffff?text=Madrasa+Events" alt="Madrasa Events" style="width: 100%; border-radius: 20px; box-shadow: 0 15px 40px rgba(0,0,0,0.1);">
                </div>
            </div>
        </div>
    </section>

    <section id="testimonials" class="section-white">
        <div class="container">
            <div class="section-header fade-up">
                <h2>What Parents Say</h2>
                <p>Read about the experiences of families who have entrusted their children's Islamic education to us.</p>
            </div>
            
            <div class="testimonial-grid">
                <div class="testimonial-card fade-up">
                    <p class="quote">"The transformation in my son's recitation is remarkable. The teachers are incredibly patient and knowledgeable."</p>
                    <div class="testimonial-author">
                        <img src="https://placehold.co/100x100/eaeaea/888888?text=A" alt="Parent" style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover;">
                        <div class="author-info">
                            <h4>Abdullah Malik</h4>
                            <span>Parent of Grade 5 Student</span>
                        </div>
                    </div>
                </div>
                
                <div class="testimonial-card fade-up" style="animation-delay: 0.1s;">
                    <p class="quote">"A beautiful environment where Islamic values are taught alongside modern methods. We couldn't be happier with Deeniyat."</p>
                    <div class="testimonial-author">
                        <img src="https://placehold.co/100x100/eaeaea/888888?text=F" alt="Parent" style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover;">
                        <div class="author-info">
                            <h4>Fatima Ahmed</h4>
                            <span>Parent of Hifz Student</span>
                        </div>
                    </div>
                </div>
                
                <div class="testimonial-card fade-up" style="animation-delay: 0.2s;">
                    <p class="quote">"The syllabus is well-structured. My daughter looks forward to attending her Arabic classes every single day."</p>
                    <div class="testimonial-author">
                        <img src="https://placehold.co/100x100/eaeaea/888888?text=T" alt="Parent" style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover;">
                        <div class="author-info">
                            <h4>Tariq Rahman</h4>
                            <span>Parent of Grade 3 Student</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="cta-section">
        <div class="container fade-up">
            <h2>Join Our Madrasa Today</h2>
            <p>Take the first step towards a comprehensive and nurturing Islamic education for your child. Enrollments are now open.</p>
            <a href="/Home/Admissions" class="btn-primary" style="background: var(--bg-white); color: var(--primary);">Apply Online Now</a>
        </div>
    </section>

    <!-- Footer -->