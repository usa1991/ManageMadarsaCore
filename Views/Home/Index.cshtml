@{
    ViewData["Title"] = "Index";
}

<!-- Promotional Swiper Banner -->
    <section class="promo-banner-slider">
        <div class="swiper promoSwiper">
            <div class="swiper-wrapper">
                <!-- Slide 1 -->
                <div class="swiper-slide">
                    <div class="promo-slide image-only" style="background-image: url('../images/image-2.jpg');">
                    </div>
                </div>
                <!-- Slide 2 -->
                <div class="swiper-slide">
                    <div class="promo-slide" style="background-image: url('../images/Homescreen-al.png');">
                        <div class="promo-content">

                        </div>
                    </div>
                </div>
                <!-- Slide 3 -->
                <div class="swiper-slide">
                    <div class="promo-slide" style="background-image: url('../images/teachersmanagement.png');">
                        <div class="promo-content">
                            <h2>New Campus Opening</h2>
                            <p>We are expanding! Visit our state-of-the-art facilities in the heart of the city.</p>
                            <a href="about.html" class="btn-primary">Read More</a>
                        </div>
                    </div>
                </div>

                <!-- Slide 4: Image Only -->
                <div class="swiper-slide">
                    <div class="promo-slide image-only"
                        style="background-image: url('../images/studentsmanagement-old.png');">
                        <!-- No text or content here, just the background image -->
                    </div>
                </div>
                <!-- Slide 5: Image Only -->
                <div class="swiper-slide">
                    <div class="promo-slide image-only" style="background-image: url('../images/CashFlow.jpg');">
                        <!-- No text or content here, just the background image -->
                    </div>
                </div>
            </div>
            <!-- Add Pagination -->
            <div class="swiper-pagination"></div>
            <!-- Add Navigation -->
            <div class="swiper-button-next"></div>
            <div class="swiper-button-prev"></div>
        </div>
    </section>

    <section class="integrated-school-section section-white" style="padding: 80px 0;">
        <div class="container fade-up" style="display: flex; flex-wrap: wrap; align-items: center; gap: 50px;">
            <div style="flex: 1; min-width: 300px;">
                <h2 style="font-size: 2.8rem; font-weight: 700; color: #333; margin-bottom: 20px; line-height: 1.2;">
                    ManageMadarsa for <span style="color: var(--primary);">Integrated Islamic Schools</span>
                </h2>
                <p style="color: #666; font-size: 1.15rem; line-height: 1.6; margin-bottom: 30px;">
                    ManageMadarsa is an advanced automated management software used for Madarsa/Maktab to manage there
                    daily activities.
                </p>
                <div style="margin-bottom: 40px;">
                    <a href="#installation" class="btn-primary"
                        style="display: inline-flex; align-items: center; gap: 8px;">Get Started <i
                            class="ph-bold ph-arrow-right"></i></a>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div style="display: flex; align-items: center; gap: 10px; color: #555; font-size: 0.95rem;">
                        <i class="ph-bold ph-check" style="color: var(--primary); font-size: 1.1rem;"></i> Student &
                        Academic Records
                    </div>
                    <div style="display: flex; align-items: center; gap: 10px; color: #555; font-size: 0.95rem;">
                        <i class="ph-bold ph-check" style="color: var(--primary); font-size: 1.1rem;"></i> Student &
                        Class Management
                    </div>
                    <div style="display: flex; align-items: center; gap: 10px; color: #555; font-size: 0.95rem;">
                        <i class="ph-bold ph-check" style="color: var(--primary); font-size: 1.1rem;"></i> Exams &
                        Progress Reports
                    </div>
                    <div style="display: flex; align-items: center; gap: 10px; color: #555; font-size: 0.95rem;">
                        <i class="ph-bold ph-check" style="color: var(--primary); font-size: 1.1rem;"></i> Fee &
                        Administration
                    </div>
                </div>
            </div>
            <div style="flex: 1; min-width: 300px; text-align: center;">
                <div style="background: #f8fbf4; border-radius: 20px; padding: 20px; border: 1px solid #eef5df;">
                    <img src="../images/6.jpg" alt="ManageMadarsa Integrated Schools"
                        style="width: 100%; max-width: 500px; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.05);"
                        onerror="this.src='https://images.unsplash.com/photo-1577563908411-50cb98976fea?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80';">
                </div>
            </div>
        </div>
    </section>

    <section class="section-cream" style="padding-top: 100px;">
        <div class="container">
            <div class="section-header fade-up">
                <h2>Why Choose Us</h2>
                <p>We provide a balanced approach to education, combining traditional Islamic teachings with modern
                    methodologies.</p>
            </div>

            <div class="features-grid">
                <div class="feature-box fade-up">
                    <i class="ph-fill ph-chalkboard-teacher"></i>
                    <h3>Students,Class,Course and Teachers</h3>
                    <p>Enroll and easily manage multiple Students,Class,Course and Teachers.</p>
                </div>
                <div class="feature-box fade-up" style="animation-delay: 0.1s;">
                    <i class="ph-fill ph-desktop"></i>
                    <h3>Examination and Report Cards</h3>
                    <p>Easily manage Monthly,Terminal,Yearly Examination and Result Cards.</p>
                </div>
                <div class="feature-box fade-up" style="animation-delay: 0.2s;">
                    <i class="ph-fill ph-book-open"></i>
                    <h3>Fees and Accounts</h3>
                    <p>Manage Complex Incoming Fees and Outgoing Expences Accounts Structure .</p>
                </div>
                <div class="feature-box fade-up" style="animation-delay: 0.3s;">
                    <i class="ph-fill ph-wallet"></i>
                    <h3>Student & Academic Records</h3>
                    <p>Manage students, classes, courses, and teachers efficiently from a single dashboard.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="section-white">
        <div class="container">
            <div class="section-header fade-up">
                <h2>Popular Courses</h2>
                <p>Discover our most sought-after programs designed for various age groups and learning levels.</p>
            </div>

            <div class="courses-preview-grid">
                <!-- Course 1 -->
                <div class="course-card fade-up">
                    <div class="course-img">
                        <img src="../images/1.jpg" alt="Quran Nazira">
                        <span class="course-badge">Beginner</span>
                    </div>
                    <div class="course-content">
                        <h3>Quran Nazira (Reading)</h3>
                        <p>Learn to read the Holy Quran with proper Tajweed rules from the basics.</p>

                    </div>
                </div>
                <!-- Course 2 -->
                <div class="course-card fade-up" style="animation-delay: 0.1s;">
                    <div class="course-img">
                        <img src="../images/2.jpg" alt="Hifz-ul-Quran">
                        <span class="course-badge">Advanced</span>
                    </div>
                    <div class="course-content">
                        <h3>Hifz-ul-Quran</h3>
                        <p>Memorization of the Holy Quran with a structured and supportive methodology.</p>

                    </div>
                </div>
                <!-- Course 3 -->
                <div class="course-card fade-up" style="animation-delay: 0.2s;">
                    <div class="course-img">
                        <img src="../images/3.jpg" alt="Islamic Studies">
                        <span class="course-badge">Intermediate</span>
                    </div>
                    <div class="course-content">
                        <h3>Islamic Studies</h3>
                        <p>Comprehensive knowledge of Fiqh, Seerah, and Hadith for daily life.</p>

                    </div>
                </div>
                <!-- Course 4 -->
                <div class="course-card fade-up">
                    <div class="course-img">
                        <img src="../images/4.jpg" alt="Arabic Language">
                        <span class="course-badge">All Levels</span>
                    </div>
                    <div class="course-content">
                        <h3>Arabic Language</h3>
                        <p>Master the language of the Quran to understand its profound meanings directly.</p>

                    </div>
                </div>
                <!-- Course 5 -->
                <div class="course-card fade-up" style="animation-delay: 0.1s;">
                    <div class="course-img">
                        <img src="../images/5.jpg" alt="Tafseer">
                        <span class="course-badge">Advanced</span>
                    </div>
                    <div class="course-content">
                        <h3>Tafseer (Exegesis)</h3>
                        <p>In-depth study and explanation of the Quranic verses and their contexts.</p>

                    </div>
                </div>
                <!-- Course 6 -->
                <div class="course-card fade-up" style="animation-delay: 0.2s;">
                    <div class="course-img">
                        <img src="../images/6.jpg" alt="Tajweed Intensive">
                        <span class="course-badge">Intermediate</span>
                    </div>
                    <div class="course-content">
                        <h3>Tajweed Intensive</h3>
                        <p>Perfect your pronunciation and recitation rules over a focused period.</p>

                    </div>
                </div>
            </div>


        </div>
    </section>



