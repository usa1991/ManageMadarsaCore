@{
    ViewData["Title"] = "Library";
}

<header class="hero section-cream" style="padding-bottom: 80px;">
        <div class="container hero-grid" style="text-align: center; display: block;">
            <div class="badge fade-up">KNOWLEDGE HUB</div>
            <h1 class="fade-up">Deeniyat Library</h1>
            <p class="fade-up" style="max-width: 600px; margin: 0 auto;">Discover thousands of books covering Quranic sciences, Hadith, Fiqh, Arabic literature, and children's stories.</p>
        </div>
    </header>

    <div class="container fade-up">
        <div class="library-search-container">
            <div class="library-search-box">
                <i class="ph-bold ph-magnifying-glass"></i>
                <input type="text" id="libSearchInput" placeholder="Search for books by title or author...">
            </div>
        </div>
    </div>

    <section class="section-white" style="padding-top: 20px;">
        <div class="container">
            
            <!-- Book Categories -->
            <div class="library-categories fade-up">
                <button class="lib-category-btn active" data-filter="all">All Books</button>
                <button class="lib-category-btn" data-filter="quran">Quran & Tafseer</button>
                <button class="lib-category-btn" data-filter="hadith">Hadith</button>
                <button class="lib-category-btn" data-filter="fiqh">Fiqh</button>
                <button class="lib-category-btn" data-filter="arabic">Arabic Language</button>
                <button class="lib-category-btn" data-filter="children">Children</button>
                <button class="lib-category-btn" data-filter="general">General</button>
            </div>
            
            <!-- Featured Books -->
            <div style="margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center;" class="fade-up">
                <h2 style="font-size: 1.5rem;"><i class="ph-fill ph-star" style="color: var(--secondary);"></i> Featured Books</h2>
            </div>
            
            <div class="books-grid fade-up" id="featuredBooks">
                <!-- Book 1 -->
                <div class="book-card" data-category="quran">
                    <img src="https://images.unsplash.com/photo-1601662528567-526cd06f6582?auto=format&fit=crop&q=80&w=800" alt="Tafseer Book" class="book-cover">
                    <div class="book-badge">FEATURED</div>
                    <div class="book-info">
                        <h3>Tafseer-e-Usmani</h3>
                        <p>Allama Shabbir Ahmad</p>
                    </div>
                    <a href="#" class="btn-borrow" onclick="event.preventDefault();"><i class="ph-bold ph-bookmark-simple"></i> Borrow</a>
                </div>

                <!-- Book 2 -->
                <div class="book-card" data-category="hadith">
                    <img src="https://images.unsplash.com/photo-1601662528567-526cd06f6582?auto=format&fit=crop&q=80&w=800" alt="Sahih Bukhari" class="book-cover">
                    <div class="book-badge">FEATURED</div>
                    <div class="book-info">
                        <h3>Sahih Bukhari (Vol 1)</h3>
                        <p>Imam Bukhari</p>
                    </div>
                    <a href="#" class="btn-borrow" onclick="event.preventDefault();"><i class="ph-bold ph-bookmark-simple"></i> Borrow</a>
                </div>

                <!-- Book 3 -->
                <div class="book-card" data-category="arabic">
                    <img src="https://images.unsplash.com/photo-1542468764-16a7f015b3c4?auto=format&fit=crop&q=80&w=800" alt="Arabic Grammar" class="book-cover">
                    <div class="book-info">
                        <h3>Qasas un Nabiyeen</h3>
                        <p>Abul Hasan Ali Nadwi</p>
                    </div>
                    <a href="#" class="btn-borrow" onclick="event.preventDefault();"><i class="ph-bold ph-bookmark-simple"></i> Borrow</a>
                </div>
                
                <!-- Book 4 -->
                <div class="book-card" data-category="children">
                    <img src="https://ui-avatars.com/api/?name=prophet stories&background=a2ae40&color=fff&size=400" alt="Prophet Stories" class="book-cover">
                    <div class="book-info">
                        <h3>Stories of Prophets</h3>
                        <p>Darussalam</p>
                    </div>
                    <a href="#" class="btn-borrow" onclick="event.preventDefault();"><i class="ph-bold ph-bookmark-simple"></i> Borrow</a>
                </div>
            </div>

            <!-- New Arrivals -->
            <div style="margin: 50px 0 20px; display: flex; justify-content: space-between; align-items: center;" class="fade-up">
                <h2 style="font-size: 1.5rem;"><i class="ph-fill ph-sparkle" style="color: var(--secondary);"></i> New Arrivals</h2>
            </div>
            
            <div class="books-grid fade-up" id="newArrivals">
                <div class="book-card" data-category="fiqh">
                    <img src="https://images.unsplash.com/photo-1601662528567-526cd06f6582?auto=format&fit=crop&q=80&w=800" alt="Fiqh Us Sunnah" class="book-cover">
                    <div class="book-info">
                        <h3>Fiqh Us Sunnah</h3>
                        <p>Sayyid Sabiq</p>
                    </div>
                    <a href="#" class="btn-borrow" onclick="event.preventDefault();"><i class="ph-bold ph-bookmark-simple"></i> Borrow</a>
                </div>
                
                <div class="book-card" data-category="general">
                    <img src="https://images.unsplash.com/photo-1601662528567-526cd06f6582?auto=format&fit=crop&q=80&w=800" alt="Islamic History" class="book-cover">
                    <div class="book-info">
                        <h3>Lost Islamic History</h3>
                        <p>Firas Alkhateeb</p>
                    </div>
                    <a href="#" class="btn-borrow" onclick="event.preventDefault();"><i class="ph-bold ph-bookmark-simple"></i> Borrow</a>
                </div>
                
                <div class="book-card" data-category="arabic">
                    <img src="https://images.unsplash.com/photo-1542468764-16a7f015b3c4?auto=format&fit=crop&q=80&w=800" alt="Madina Arabic" class="book-cover">
                    <div class="book-info">
                        <h3>Madina Arabic Reader</h3>
                        <p>Dr. V. Abdur Rahim</p>
                    </div>
                    <a href="#" class="btn-borrow" onclick="event.preventDefault();"><i class="ph-bold ph-bookmark-simple"></i> Borrow</a>
                </div>
            </div>

            <div id="noResults" style="display: none; text-align: center; padding: 40px; color: var(--text-muted);">
                No books found matching your search.
            </div>

            <!-- Digital Library Promo -->
            <div class="digital-lib-promo fade-up">
                <div class="digital-lib-content">
                    <h2>Deeniyat Digital Library</h2>
                    <p>Can't visit the physical library? Access over 5,000+ digital books, audio lectures, and interactive resources from the comfort of your home.</p>
                    <a href="#" class="btn-secondary" style="border: none;" onclick="event.preventDefault();">Explore E-Library <i class="ph-bold ph-arrow-right"></i></a>
                </div>
                <div class="digital-lib-icon">
                    <i class="ph-fill ph-device-tablet-speaker"></i>
                </div>
            </div>

            <!-- Borrowing Rules & Timings -->
            <div style="margin-bottom: 20px;" class="fade-up">
                <h2 style="font-size: 1.8rem; text-align: center; margin-bottom: 40px;">Library Guidelines</h2>
            </div>
            
            <div class="rules-grid fade-up" style="margin-bottom: 60px;">
                <div class="rule-card">
                    <i class="ph-fill ph-clock-countdown"></i>
                    <h3>Borrowing Duration</h3>
                    <p>Students can borrow up to 3 books at a time for a maximum duration of 14 days. Renewals are permitted if the book is not on hold.</p>
                </div>
                <div class="rule-card">
                    <i class="ph-fill ph-identification-card"></i>
                    <h3>Library Card</h3>
                    <p>A valid student ID or Library Card must be presented at the circulation desk for checking out any materials.</p>
                </div>
                <div class="rule-card">
                    <i class="ph-fill ph-calendar-check"></i>
                    <h3>Library Timings</h3>
                    <p><strong>Mon - Thu:</strong> 8:00 AM - 5:00 PM<br><strong>Friday:</strong> 8:00 AM - 12:30 PM<br><strong>Weekend:</strong> Closed</p>
                </div>
            </div>

        </div>
    </section>

    <!-- Footer -->