@{
    ViewData["Title"] = "News & Announcements";
}

<!-- Hero Banner -->
    <header class="section-cream" style="padding: 160px 0 80px;">
        <div class="container" style="text-align: center;">
            <div class="badge">STAY UPDATED</div>
            <h1 style="font-size: 3.2rem; margin-bottom: 24px;">News & Announcements</h1>
            <p style="font-size: 1.1rem; color: var(--text-muted); max-width: 600px; margin: 0 auto 30px;">Keep up with the latest events, exam schedules, competition results, and community announcements at Deeniyat.</p>
        </div>
    </header>

    <!-- Main Content -->
    <section class="section-white">
        <div class="container">
            <div class="news-layout">
                
                <!-- Main News Column -->
                <div>
                    <h2 style="font-size: 2rem; margin-bottom: 30px;">Latest News</h2>
                    
                    <div class="news-grid">
                        <!-- News Card 1 -->
                        <div class="news-card">
                            <img src="https://images.unsplash.com/photo-1579808608826-64195fc166ba?auto=format&fit=crop&q=80&w=800" alt="News Image" class="news-image">
                            <div class="news-content">
                                <div class="news-meta">
                                    <span class="news-category">Events</span>
                                    <span>July 05, 2026</span>
                                </div>
                                <h3 class="news-title">Annual Jalsa & Awards Ceremony 2026</h3>
                                <a href="#" class="news-read-more">Read More <i class="ph-bold ph-arrow-right"></i></a>
                            </div>
                        </div>

                        <!-- News Card 2 -->
                        <div class="news-card">
                            <img src="https://ui-avatars.com/api/?name=admissions open&background=a2ae40&color=fff&size=400" alt="News Image" class="news-image">
                            <div class="news-content">
                                <div class="news-meta">
                                    <span class="news-category">Admissions</span>
                                    <span>June 28, 2026</span>
                                </div>
                                <h3 class="news-title">Admissions Open for Academic Year 2026-2027</h3>
                                <a href="#" class="news-read-more">Read More <i class="ph-bold ph-arrow-right"></i></a>
                            </div>
                        </div>

                        <!-- News Card 3 -->
                        <div class="news-card">
                            <img src="https://images.unsplash.com/photo-1526676037777-05a232554f77?auto=format&fit=crop&q=80&w=800" alt="News Image" class="news-image">
                            <div class="news-content">
                                <div class="news-meta">
                                    <span class="news-category">Competitions</span>
                                    <span>June 15, 2026</span>
                                </div>
                                <h3 class="news-title">Inter-Madarsa Qiraat Competition Winners</h3>
                                <a href="#" class="news-read-more">Read More <i class="ph-bold ph-arrow-right"></i></a>
                            </div>
                        </div>

                        <!-- News Card 4 -->
                        <div class="news-card">
                            <img src="https://ui-avatars.com/api/?name=mid-term exams&background=a2ae40&color=fff&size=400" alt="News Image" class="news-image">
                            <div class="news-content">
                                <div class="news-meta">
                                    <span class="news-category">Exams</span>
                                    <span>June 02, 2026</span>
                                </div>
                                <h3 class="news-title">Mid-Term Examination Schedule Released</h3>
                                <a href="#" class="news-read-more">Read More <i class="ph-bold ph-arrow-right"></i></a>
                            </div>
                        </div>
                        
                        <!-- News Card 5 -->
                        <div class="news-card">
                            <img src="https://ui-avatars.com/api/?name=term 1 results&background=a2ae40&color=fff&size=400" alt="News Image" class="news-image">
                            <div class="news-content">
                                <div class="news-meta">
                                    <span class="news-category">Results</span>
                                    <span>May 20, 2026</span>
                                </div>
                                <h3 class="news-title">Term 1 Results Are Now Available Online</h3>
                                <a href="#" class="news-read-more">Read More <i class="ph-bold ph-arrow-right"></i></a>
                            </div>
                        </div>

                        <!-- News Card 6 -->
                        <div class="news-card">
                            <img src="https://ui-avatars.com/api/?name=parent meeting&background=a2ae40&color=fff&size=400" alt="News Image" class="news-image">
                            <div class="news-content">
                                <div class="news-meta">
                                    <span class="news-category">Events</span>
                                    <span>May 10, 2026</span>
                                </div>
                                <h3 class="news-title">Parent-Teacher Meeting Scheduled for This Weekend</h3>
                                <a href="#" class="news-read-more">Read More <i class="ph-bold ph-arrow-right"></i></a>
                            </div>
                        </div>
                    </div>

                    <!-- Pagination -->
                    <div class="pagination">
                        <a href="#" class="page-btn"><i class="ph-bold ph-caret-left"></i></a>
                        <a href="#" class="page-btn active">1</a>
                        <a href="#" class="page-btn">2</a>
                        <a href="#" class="page-btn">3</a>
                        <span style="display:flex; align-items:end; padding: 0 5px;">...</span>
                        <a href="#" class="page-btn">8</a>
                        <a href="#" class="page-btn"><i class="ph-bold ph-caret-right"></i></a>
                    </div>
                </div>

                <!-- Sidebar -->
                <aside class="sidebar">
                    <!-- Search Widget -->
                    <div class="sidebar-widget">
                        <h3>Search News</h3>
                        <div class="search-box">
                            <input type="text" placeholder="Search...">
                            <button><i class="ph-bold ph-magnifying-glass"></i></button>
                        </div>
                    </div>

                    <!-- Categories Widget -->
                    <div class="sidebar-widget">
                        <h3>Categories</h3>
                        <ul class="category-list">
                            <li><a href="#">Admissions <span>(12)</span></a></li>
                            <li><a href="#">Events <span>(34)</span></a></li>
                            <li><a href="#">Competitions <span>(8)</span></a></li>
                            <li><a href="#">Results <span>(15)</span></a></li>
                            <li><a href="#">Exams <span>(22)</span></a></li>
                        </ul>
                    </div>

                    <!-- Recent Posts Widget -->
                    <div class="sidebar-widget">
                        <h3>Recent Posts</h3>
                        <div class="sidebar-post">
                            <img src="https://images.unsplash.com/photo-1584286595398-a59f21d313f5?auto=format&fit=crop&q=80&w=800" alt="Thumbnail" class="sidebar-post-img">
                            <div class="sidebar-post-info">
                                <h4><a href="#">Annual Jalsa & Awards Ceremony 2026</a></h4>
                                <span>July 05, 2026</span>
                            </div>
                        </div>
                        <div class="sidebar-post">
                            <img src="https://images.unsplash.com/photo-1584286595398-a59f21d313f5?auto=format&fit=crop&q=80&w=800" alt="Thumbnail" class="sidebar-post-img">
                            <div class="sidebar-post-info">
                                <h4><a href="#">Admissions Open for 2026-2027</a></h4>
                                <span>June 28, 2026</span>
                            </div>
                        </div>
                        <div class="sidebar-post">
                            <img src="https://images.unsplash.com/photo-1584286595398-a59f21d313f5?auto=format&fit=crop&q=80&w=800" alt="Thumbnail" class="sidebar-post-img">
                            <div class="sidebar-post-info">
                                <h4><a href="#">Inter-Madarsa Qiraat Winners</a></h4>
                                <span>June 15, 2026</span>
                            </div>
                        </div>
                    </div>

                    <!-- Popular Posts Widget -->
                    <div class="sidebar-widget">
                        <h3>Popular Posts</h3>
                        <div class="sidebar-post">
                            <img src="https://images.unsplash.com/photo-1584286595398-a59f21d313f5?auto=format&fit=crop&q=80&w=800" alt="Thumbnail" class="sidebar-post-img">
                            <div class="sidebar-post-info">
                                <h4><a href="#">How to Register on the Parent Portal</a></h4>
                                <span>January 10, 2026</span>
                            </div>
                        </div>
                        <div class="sidebar-post">
                            <img src="https://images.unsplash.com/photo-1584286595398-a59f21d313f5?auto=format&fit=crop&q=80&w=800" alt="Thumbnail" class="sidebar-post-img">
                            <div class="sidebar-post-info">
                                <h4><a href="#">Updated Hifz Syllabus 2026</a></h4>
                                <span>February 05, 2026</span>
                            </div>
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </section>

    <!-- Newsletter Subscription -->
    <section class="section-cream" style="padding: 80px 0; text-align: center;">
        <div class="container">
            <div style="max-width: 600px; margin: 0 auto;">
                <i class="ph-fill ph-envelope-simple-open" style="font-size: 3rem; color: var(--primary); margin-bottom: 20px;"></i>
                <h2 style="font-size: 2.2rem; margin-bottom: 15px;">Subscribe to Our Newsletter</h2>
                <p style="color: var(--text-muted); font-size: 1.1rem; margin-bottom: 30px;">
                    Get the latest updates, event invitations, and announcements delivered directly to your inbox.
                </p>
                <form class="search-box" style="justify-content: center; max-width: 500px; margin: 0 auto;">
                    <input type="email" placeholder="Your Email Address" required style="padding: 14px; font-size: 1rem;">
                    <button type="submit" style="padding: 14px 24px; font-size: 1rem; font-weight: 600;">Subscribe</button>
                </form>
            </div>
        </div>
    </section>

    <!-- Footer -->
