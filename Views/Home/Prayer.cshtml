            </div>
            <h1 class="fade-up" style="font-size: 3rem; margin-bottom: 10px;">Today's Prayer Times</h1>
            <p class="fade-up">New York, NY (Local Madrasa Timings)</p>
            
            <div class="prayer-cards-container fade-up">
                <div class="prayer-card">
                    <h4>Fajr</h4>
                    <div class="time">5:15 AM</div>
                </div>
                <div class="prayer-card">
                    <h4>Sunrise</h4>
                    <div class="time">6:30 AM</div>
                </div>
                <div class="prayer-card current">
                    <h4>Dhuhr</h4>
                    <div class="time">1:10 PM</div>
                </div>
                <div class="prayer-card">
                    <h4>Asr</h4>
                    <div class="time">5:05 PM</div>
                </div>
                <div class="prayer-card">
                    <h4>Maghrib</h4>
