                        <div class="arabic">
                            رَبِّ زِدْنِي عِلْمًا
                        </div>
                        <div class="translation">
                            "My Lord, increase me in knowledge."
                        </div>
                        <p style="font-size: 0.8rem; margin-top: 15px; color: rgba(255,255,255,0.5);">[Surah Ta-Ha 20:114]</p>
                    </div>
                    
