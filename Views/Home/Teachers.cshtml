@{
    ViewData["Title"] = "Teachers";
}

<!-- Hero Banner -->
    <header class="section-cream" style="padding: 160px 0 80px;">
        <div class="container" style="text-align: center;">
            <div class="badge">OUR FACULTY</div>
            <h1 style="font-size: 3.2rem; margin-bottom: 24px;">Meet Our Teachers</h1>
            <p style="font-size: 1.1rem; color: var(--text-muted); max-width: 600px; margin: 0 auto;">Dedicated, highly qualified, and deeply experienced professionals shaping the future of our students.</p>
        </div>
    </header>

    <!-- Featured Teacher Section -->
    <section class="section-white">
        <div class="container">
            <div class="featured-teacher-grid">
                <div class="hero-image">
                    <img src="../images/featured-teacher.jpg" onerror="this.src='https://ui-avatars.com/api/?name=featured teacher&background=a2ae40&color=fff&size=400';" alt="Featured Teacher">
                </div>
                <div>
                    <div class="badge" style="margin-bottom: 16px;">FEATURED TEACHER</div>
                    <h2 style="font-size: 2.5rem; margin-bottom: 8px;">Sheikh Abdullah</h2>
                    <p style="color: var(--primary); font-weight: 600; font-size: 1.1rem; margin-bottom: 24px;">Head of Islamic Studies | Ph.D. in Arabic Literature</p>
                    
                    <p style="color: var(--text-muted); margin-bottom: 16px; font-size: 1.05rem;">With over 15 years of experience in classical Islamic studies and modern pedagogical methods, Sheikh Abdullah leads our curriculum development.</p>
                    <p style="color: var(--text-muted); margin-bottom: 24px; font-size: 1.05rem;">His unique approach seamlessly integrates traditional values with contemporary digital learning tools, ensuring students not only memorize texts but profoundly understand them.</p>
                    
                    <div style="display: flex; gap: 16px; margin-bottom: 32px;">
                        <div class="meta-tag"><i class="ph-fill ph-clock"></i> 15+ Years Exp.</div>
                        <div class="meta-tag"><i class="ph-fill ph-star"></i> Lead Developer</div>
                    </div>
                    
                    <a href="#" class="btn-secondary">Read Full Bio</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Teacher Grid -->
    <section class="section-cream">
        <div class="container">
            <div class="section-header">
                <h2>Our Teaching Staff</h2>
                <p>A diverse team of experts committed to excellence.</p>
            </div>
            
            <div class="teacher-grid">
                <!-- Teacher 1 -->
                <div class="teacher-card">
                    <img src="../images/t1.jpg" onerror="this.src='https://ui-avatars.com/api/?name=Mohd+Aqsad+Ali+Nadwi&background=a2ae40&color=fff&size=400';" alt="Mohd Aqsad Ali Nadwi" class="teacher-photo">
                    <div class="teacher-info">
                        <h3 class="teacher-name">Mohd Aqsad Ali Nadwi</h3>
                        <div class="teacher-qualification">Fazilat & P.G. Diploma in Islamic Studies</div>
                        <div class="teacher-meta">
                            <span class="meta-tag"><i class="ph-bold ph-briefcase"></i> 12 YRS EXP</span>
                            <span class="meta-tag"><i class="ph-bold ph-bookmark"></i> INTERNATIONAL TEACHER TRAINING</span>
                        </div>
                        <p class="teacher-bio">An international master trainer specializing in Islamic pedagogy. Over 12 years of global experience training Maktab educators across India, Bahrain, Fiji, and Bangladesh.</p>
                    </div>
                </div>

                <!-- Teacher 2 -->
                <div class="teacher-card">
                    <img src="../images/teacher2.jpg" onerror="this.src='https://ui-avatars.com/api/?name=teacher 2&background=a2ae40&color=fff&size=400';" alt="Teacher" class="teacher-photo">
                    <div class="teacher-info">
                        <h3 class="teacher-name">Hafiz Qasim</h3>
                        <div class="teacher-qualification">Ijazah in Tajweed</div>
                        <div class="teacher-meta">
                            <span class="meta-tag"><i class="ph-bold ph-briefcase"></i> 12 YRS EXP</span>
                            <span class="meta-tag"><i class="ph-bold ph-bookmark"></i> Quranic Recitation</span>
                        </div>
                        <p class="teacher-bio">Passionate about preserving the authentic recitation of the Quran. Leads the Hifz program.</p>
                    </div>
                </div>

                <!-- Teacher 3 -->
                <div class="teacher-card">
                    <img src="../images/teacher3.jpg" onerror="this.src='https://ui-avatars.com/api/?name=teacher 3&background=a2ae40&color=fff&size=400';" alt="Teacher" class="teacher-photo">
                    <div class="teacher-info">
                        <h3 class="teacher-name">Aisha Rahman</h3>
                        <div class="teacher-qualification">B.Ed. & B.A. Arabic</div>
                        <div class="teacher-meta">
                            <span class="meta-tag"><i class="ph-bold ph-briefcase"></i> 5 YRS EXP</span>
                            <span class="meta-tag"><i class="ph-bold ph-bookmark"></i> Arabic Language</span>
                        </div>
                        <p class="teacher-bio">Focuses on interactive and conversational Arabic, ensuring students can confidently engage with original texts.</p>
                    </div>
                </div>
                
                <!-- Teacher 4 -->
                <div class="teacher-card">
                    <img src="../images/teacher4.jpg" onerror="this.src='https://ui-avatars.com/api/?name=teacher 4&background=a2ae40&color=fff&size=400';" alt="Teacher" class="teacher-photo">
                    <div class="teacher-info">
                        <h3 class="teacher-name">Moulana Zaid</h3>
                        <div class="teacher-qualification">Aalimiyyah Degree</div>
                        <div class="teacher-meta">
                            <span class="meta-tag"><i class="ph-bold ph-briefcase"></i> 10 YRS EXP</span>
                            <span class="meta-tag"><i class="ph-bold ph-bookmark"></i> Hadith Studies</span>
                        </div>
                        <p class="teacher-bio">Dedicated to teaching the traditions of the Prophet (PBUH) with practical applications for modern life.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Teacher Achievements -->
    <section class="section-white">
        <div class="container">
            <div class="section-header">
                <h2>Our Achievements</h2>
                <p>The collective impact of our dedicated faculty.</p>
            </div>
            
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-number">150+</div>
                    <div class="stat-label">Certified Educators</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">10k+</div>
                    <div class="stat-label">Students Mentored</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">25</div>
                    <div class="stat-label">Global Awards</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">100%</div>
                    <div class="stat-label">Commitment</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Teaching Methodology -->
    <section class="section-cream">
        <div class="container">
            <div class="section-header">
                <h2>Teaching Methodology</h2>
                <p>How we ensure effective learning.</p>
            </div>
            
            <div class="feature-grid">
                <div class="feature-card">
                    <div class="feature-icon-top" style="color: var(--primary); font-size: 2rem; margin-bottom: 16px;"><i class="ph-fill ph-chalkboard-teacher"></i></div>
                    <h3>Interactive Sessions</h3>
                    <p>Moving away from rote memorization, we encourage discussion, Q&A, and active participation in every class.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon-top" style="color: var(--primary); font-size: 2rem; margin-bottom: 16px;"><i class="ph-fill ph-devices"></i></div>
                    <h3>Digital Integration</h3>
                    <p>We utilize the Deeniyat app to provide visual aids, track progress, and give students access to supplementary materials.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon-top" style="color: var(--primary); font-size: 2rem; margin-bottom: 16px;"><i class="ph-fill ph-users"></i></div>
                    <h3>Personalized Attention</h3>
                    <p>Maintaining optimal student-to-teacher ratios to ensure every student's unique learning pace is respected and supported.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Become a Teacher CTA -->
    <section class="section-white" style="text-align: center; padding: 60px 0;">
        <div class="container">
            <h2 style="font-size: 2.5rem; margin-bottom: 20px;">Join Our Faculty</h2>
            <p style="color: var(--text-muted); font-size: 1.1rem; margin-bottom: 30px; max-width: 600px; margin-left: auto; margin-right: auto;">Are you passionate about education and shaping the next generation? We are always looking for dedicated educators to join our growing family.</p>
            <a href="#" class="btn-primary" style="font-size: 1.1rem; padding: 14px 32px;"><i class="ph-bold ph-briefcase"></i> View Open Positions</a>
        </div>
    </section>

    <!-- Footer -->
