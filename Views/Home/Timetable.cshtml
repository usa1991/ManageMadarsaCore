@{
    ViewData["Title"] = "Timetable";
}

<!-- Hero Banner -->
    <header class="section-cream" style="padding: 160px 0 80px;">
        <div class="container" style="text-align: center;">
            <div class="badge">ACADEMIC CALENDAR</div>
            <h1 style="font-size: 3.2rem; margin-bottom: 24px;">Weekly Schedule</h1>
            <p style="font-size: 1.1rem; color: var(--text-muted); max-width: 600px; margin: 0 auto 30px;">Stay organized with our comprehensive timetable, prayer breaks, and holiday calendar.</p>
            <a href="#" class="btn-primary" style="padding: 12px 28px;"><i class="ph-bold ph-download-simple"></i> Download PDF</a>
        </div>
    </header>

    <!-- Timetable Section -->
    <section class="section-white">
        <div class="container">
            <div class="section-header">
                <h2>Interactive Timetable</h2>
                <p>Scroll horizontally to view the full schedule on mobile devices.</p>
            </div>
            
            <div class="timetable-wrapper">
                <table class="timetable">
                    <thead>
                        <tr>
                            <th class="time-col">Time</th>
                            <th>Monday</th>
                            <th>Tuesday</th>
                            <th>Wednesday</th>
                            <th>Thursday</th>
                            <th>Friday</th>
                            <th>Saturday</th>
                            <th>Sunday</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Morning -->
                        <tr>
                            <td class="time-col">Morning<br><span style="font-size: 0.8rem; font-weight: 400; color: var(--text-muted);">08:00 AM - 12:00 PM</span></td>
                            <td>
                                <div class="class-slot class-hifz"><span>Hifz Program</span><span>Room 101</span></div>
                                <div class="class-slot class-qaida"><span>Qaida Basics</span><span>Room 102</span></div>
                            </td>
                            <td>
                                <div class="class-slot class-hifz"><span>Hifz Program</span><span>Room 101</span></div>
                                <div class="class-slot class-qaida"><span>Qaida Basics</span><span>Room 102</span></div>
                            </td>
                            <td>
                                <div class="class-slot class-hifz"><span>Hifz Program</span><span>Room 101</span></div>
                                <div class="class-slot class-qaida"><span>Qaida Basics</span><span>Room 102</span></div>
                            </td>
                            <td>
                                <div class="class-slot class-hifz"><span>Hifz Program</span><span>Room 101</span></div>
                                <div class="class-slot class-qaida"><span>Qaida Basics</span><span>Room 102</span></div>
                            </td>
                            <td>
                                <div class="class-slot class-hifz"><span>Hifz Program</span><span>Room 101</span></div>
                                <div class="class-slot class-qaida"><span>Qaida Basics</span><span>Room 102</span></div>
                            </td>
                            <td>
                                <div class="class-slot class-arabic"><span>Arabic Weekend</span><span>Room 201</span></div>
                            </td>
                            <td>
                                <div class="class-slot class-arabic"><span>Arabic Weekend</span><span>Room 201</span></div>
                            </td>
                        </tr>
                        
                        <!-- Lunch/Prayer Break -->
                        <tr>
                            <td class="time-col">Break<br><span style="font-size: 0.8rem; font-weight: 400; color: var(--text-muted);">12:00 PM - 01:30 PM</span></td>
                            <td colspan="5"><div class="class-slot class-break">Zuhr Prayer & Lunch Break</div></td>
                            <td colspan="2"><div class="class-slot class-break">Zuhr Prayer & Break</div></td>
                        </tr>

                        <!-- Afternoon -->
                        <tr>
                            <td class="time-col">Afternoon<br><span style="font-size: 0.8rem; font-weight: 400; color: var(--text-muted);">01:30 PM - 04:30 PM</span></td>
                            <td>
                                <div class="class-slot class-tajweed"><span>Tajweed</span><span>Room 205</span></div>
                            </td>
                            <td>
                                <div class="class-slot class-tajweed"><span>Tajweed</span><span>Room 205</span></div>
                            </td>
                            <td>
                                <div class="class-slot class-tajweed"><span>Tajweed</span><span>Room 205</span></div>
                            </td>
                            <td>
                                <div class="class-slot class-tajweed"><span>Tajweed</span><span>Room 205</span></div>
                            </td>
                            <td>
                                <div class="class-slot class-break">Jumu'ah Preparation (Half Day)</div>
                            </td>
                            <td>
                                <div class="class-slot class-tajweed"><span>Tajweed Weekend</span><span>Room 205</span></div>
                            </td>
                            <td>
                                <div class="class-slot class-tajweed"><span>Tajweed Weekend</span><span>Room 205</span></div>
                            </td>
                        </tr>
                        
                        <!-- Asr Break -->
                        <tr>
                            <td class="time-col">Break<br><span style="font-size: 0.8rem; font-weight: 400; color: var(--text-muted);">04:30 PM - 05:00 PM</span></td>
                            <td colspan="7"><div class="class-slot class-break">Asr Prayer Break</div></td>
                        </tr>

                        <!-- Evening -->
                        <tr>
                            <td class="time-col">Evening<br><span style="font-size: 0.8rem; font-weight: 400; color: var(--text-muted);">05:00 PM - 07:30 PM</span></td>
                            <td>
                                <div class="class-slot class-qaida"><span>Qaida Evening</span><span>Room 102</span></div>
                            </td>
                            <td>
                                <div class="class-slot class-qaida"><span>Qaida Evening</span><span>Room 102</span></div>
                            </td>
                            <td>
                                <div class="class-slot class-qaida"><span>Qaida Evening</span><span>Room 102</span></div>
                            </td>
                            <td>
                                <div class="class-slot class-qaida"><span>Qaida Evening</span><span>Room 102</span></div>
                            </td>
                            <td>
                                <div class="class-slot class-qaida"><span>Qaida Evening</span><span>Room 102</span></div>
                            </td>
                            <td><div class="class-slot class-break">Closed</div></td>
                            <td><div class="class-slot class-break">Closed</div></td>
                        </tr>
                    </tbody>
                </table>
            </div>
            
            <!-- Legend -->
            <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
                <div style="display: flex; align-items: center; gap: 8px;"><div style="width: 16px; height: 16px; border-radius: 4px; background: #e3f2fd;"></div> <span style="font-size: 0.9rem; color: var(--text-muted);">Qaida</span></div>
                <div style="display: flex; align-items: center; gap: 8px;"><div style="width: 16px; height: 16px; border-radius: 4px; background: var(--primary-light);"></div> <span style="font-size: 0.9rem; color: var(--text-muted);">Hifz</span></div>
                <div style="display: flex; align-items: center; gap: 8px;"><div style="width: 16px; height: 16px; border-radius: 4px; background: #fff3e0;"></div> <span style="font-size: 0.9rem; color: var(--text-muted);">Tajweed</span></div>
                <div style="display: flex; align-items: center; gap: 8px;"><div style="width: 16px; height: 16px; border-radius: 4px; background: #f3e5f5;"></div> <span style="font-size: 0.9rem; color: var(--text-muted);">Arabic</span></div>
            </div>
        </div>
    </section>

    <!-- Important Information Grid -->
    <section class="section-cream">
        <div class="container">
            <div class="feature-grid" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));">
                
                <!-- Important Timings & Prayers -->
                <div class="feature-card">
                    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px;">
                        <i class="ph-fill ph-clock" style="font-size: 2rem; color: var(--primary);"></i>
                        <h3 style="margin: 0; font-size: 1.5rem;">Important Timings</h3>
                    </div>
                    <ul class="info-list">
                        <li><span>Building Opens</span> <strong>07:30 AM</strong></li>
                        <li><span>Zuhr Jama'at</span> <strong>01:15 PM</strong></li>
                        <li><span>Asr Jama'at</span> <strong>04:45 PM</strong></li>
                        <li><span>Maghrib Break</span> <strong>Variable (Sunset)</strong></li>
                        <li><span>Building Closes</span> <strong>08:00 PM</strong></li>
                    </ul>
                </div>

                <!-- Exam Schedule -->
                <div class="feature-card">
                    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px;">
                        <i class="ph-fill ph-exam" style="font-size: 2rem; color: var(--primary);"></i>
                        <h3 style="margin: 0; font-size: 1.5rem;">Exam Schedule 2026</h3>
                    </div>
                    <ul class="info-list">
                        <li><span>First Term Exams</span> <strong>March 10 - 20</strong></li>
                        <li><span>Mid-Year Finals</span> <strong>June 15 - 25</strong></li>
                        <li><span>Second Term Exams</span> <strong>Sept 10 - 20</strong></li>
                        <li><span>Annual Final Exams</span> <strong>Dec 05 - 18</strong></li>
                        <li><span>Result Declaration</span> <strong>Dec 24</strong></li>
                    </ul>
                </div>

                <!-- Holiday Calendar -->
                <div class="feature-card">
                    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px;">
                        <i class="ph-fill ph-calendar-blank" style="font-size: 2rem; color: var(--primary);"></i>
                        <h3 style="margin: 0; font-size: 1.5rem;">Holiday Calendar</h3>
                    </div>
                    <ul class="info-list">
                        <li><span>Eid ul-Fitr</span> <strong>March 20 - 25*</strong></li>
                        <li><span>Eid ul-Adha</span> <strong>May 27 - Jun 2*</strong></li>
                        <li><span>Summer Break</span> <strong>July 01 - July 15</strong></li>
                        <li><span>Winter Break</span> <strong>Dec 25 - Jan 01</strong></li>
                        <li style="font-size: 0.8rem; color: var(--text-muted); border: none; padding-bottom: 0;">* Subject to moon sighting</li>
                    </ul>
                </div>

            </div>
        </div>
    </section>
